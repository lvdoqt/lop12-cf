---
interface Props {
  title: string;
  value: string | number;
  description?: string;
  icon?: 'lessons' | 'exams' | 'score' | 'progress';
  color?: 'blue' | 'emerald' | 'amber' | 'purple' | 'rose';
}

const { title, value, description, icon = 'lessons', color = 'blue' } = Astro.props;

const colorMap = {
  blue: {
    bg: 'bg-blue-50 dark:bg-blue-950/15',
    border: 'border-blue-100 dark:border-blue-900/35',
    text: 'text-blue-600 dark:text-blue-400',
    iconBg: 'bg-blue-600/10 text-blue-600 dark:bg-blue-500/10 dark:text-blue-400',
    badge: 'bg-blue-500/10 text-blue-600 dark:text-blue-400'
  },
  emerald: {
    bg: 'bg-emerald-50 dark:bg-emerald-950/15',
    border: 'border-emerald-100 dark:border-emerald-900/35',
    text: 'text-emerald-600 dark:text-emerald-400',
    iconBg: 'bg-emerald-600/10 text-emerald-600 dark:bg-emerald-500/10 dark:text-emerald-400',
    badge: 'bg-emerald-500/10 text-emerald-600 dark:text-emerald-400'
  },
  amber: {
    bg: 'bg-amber-50 dark:bg-amber-950/15',
    border: 'border-amber-100 dark:border-amber-900/35',
    text: 'text-amber-600 dark:text-amber-400',
    iconBg: 'bg-amber-600/10 text-amber-600 dark:bg-amber-500/10 dark:text-amber-400',
    badge: 'bg-amber-500/10 text-amber-600 dark:text-amber-400'
  },
  purple: {
    bg: 'bg-purple-50 dark:bg-purple-950/15',
    border: 'border-purple-100 dark:border-purple-900/35',
    text: 'text-purple-600 dark:text-purple-400',
    iconBg: 'bg-purple-600/10 text-purple-600 dark:bg-purple-500/10 dark:text-purple-400',
    badge: 'bg-purple-500/10 text-purple-600 dark:text-purple-400'
  },
  rose: {
    bg: 'bg-rose-50 dark:bg-rose-950/15',
    border: 'border-rose-100 dark:border-rose-900/35',
    text: 'text-rose-600 dark:text-rose-400',
    iconBg: 'bg-rose-600/10 text-rose-600 dark:bg-rose-500/10 dark:text-rose-400',
    badge: 'bg-rose-500/10 text-rose-600 dark:text-rose-400'
  }
};

const style = colorMap[color];
---

<div class={`p-6 rounded-2xl border ${style.bg} ${style.border} hover:shadow-lg hover:shadow-gray-150/20 dark:hover:shadow-none transition-all duration-200 group`}>
  <div class="flex items-center justify-between">
    <div>
      <p class="text-xs font-semibold text-gray-500 dark:text-slate-400 uppercase tracking-wider">{title}</p>
      <h3 class="text-2xl md:text-3xl font-extrabold text-gray-900 dark:text-white mt-2 tracking-tight group-hover:scale-[1.02] origin-left transition-transform duration-200">{value}</h3>
    </div>
    
    <div class={`w-12 h-12 rounded-xl flex items-center justify-center ${style.iconBg} shadow-sm transition-transform duration-300 group-hover:rotate-6`}>
      {icon === 'lessons' && (
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>
      )}
      {icon === 'exams' && (
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
        </svg>
      )}
      {icon === 'score' && (
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      )}
      {icon === 'progress' && (
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
      )}
    </div>
  </div>
  
  {description && (
    <div class="mt-4 pt-4 border-t border-gray-150/40 dark:border-slate-800/40">
      <p class="text-xs text-gray-500 dark:text-slate-400 flex items-center font-medium">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1 text-gray-400 dark:text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        {description}
      </p>
    </div>
  )}
</div>
