---
interface Props {
  progress: number; // 0 to 100
  color?: 'blue' | 'emerald' | 'amber';
}

const { progress = 0, color = 'blue' } = Astro.props;

const cappedProgress = Math.min(100, Math.max(0, Math.round(progress)));

const colorClasses = {
  blue: 'from-blue-500 to-indigo-600 dark:from-blue-400 dark:to-indigo-500 shadow-blue-500/10',
  emerald: 'from-emerald-500 to-teal-600 dark:from-emerald-400 dark:to-teal-500 shadow-emerald-500/10',
  amber: 'from-amber-500 to-orange-600 dark:from-amber-400 dark:to-orange-500 shadow-amber-500/10'
};
---

<div class="w-full">
  <div class="flex items-center justify-between mb-1.5 text-xs font-semibold text-gray-500 dark:text-slate-400">
    <span>Tiến độ học tập</span>
    <span class="text-gray-900 dark:text-white font-bold">{cappedProgress}%</span>
  </div>
  
  <div class="w-full h-3 bg-gray-200/70 dark:bg-slate-800/80 rounded-full overflow-hidden p-0.5 border border-gray-250/20 dark:border-slate-700/35">
    <div
      class={`h-full rounded-full bg-gradient-to-r ${colorClasses[color]} shadow-md transition-all duration-500 ease-out`}
      style={`width: ${cappedProgress}%`}
    >
    </div>
  </div>
</div>
