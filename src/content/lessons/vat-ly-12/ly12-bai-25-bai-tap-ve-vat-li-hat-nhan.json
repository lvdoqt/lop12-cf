      "content": {
        "theory": {
          "title": "Tổng hợp kiến thức Vật lí hạt nhân",
          "sections": [
            {
              "heading": "1. Cấu trúc hạt nhân",
              "content": "<p><strong>Hạt nhân:</strong> Z proton + N neutron</p><p><strong>Ký hiệu:</strong> ^A_ZX</p><p><strong>Đơn vị khối lượng:</strong> 1u = 1,66.10⁻²⁷ kg</p><p><strong>Bán kính:</strong> R = r₀.A^(1/3) với r₀ = 1,2 fm</p>"
            },
            {
              "heading": "2. Năng lượng liên kết",
              "content": "<p><strong>Độ hụt khối:</strong> Δm = [Z.m_p + N.m_n] - m_X</p><p><strong>Năng lượng liên kết:</strong> E_lk = Δm.c²</p><p><strong>Năng lượng liên kết riêng:</strong> ε = E_lk/A</p>"
            },
            {
              "heading": "3. Phóng xạ",
              "content": "<p><strong>Định luật phóng xạ:</strong> N = N₀.2^(-t/T)</p><p><strong>Chu kỳ bán rã:</strong> T</p><p><strong>Hoạt động phóng xạ:</strong> A = A₀.2^(-t/T)</p><p><strong>Các tia:</strong> α, β, γ</p>"
            },
            {
              "heading": "4. Phản ứng hạt nhân",
              "content": "<p><strong>Phân hạch:</strong> Hạt nhân nặng vỡ</p><p><strong>Nhiệt hạch:</strong> Hạt nhân nhẹ tổng hợp</p><p><strong>Bảo toàn:</strong> Số nuclon, điện tích, năng lượng</p>"
            }
          ]
        },
        "problemTypes": [
          {
            "id": "dang1",
            "name": "Dạng 1: Bài tập cấu trúc hạt nhân",
            "method": "<p><strong>Phương pháp:</strong></p><ul><li>N = A - Z</li><li>R = r₀.A^(1/3)</li></ul>",
            "examples": [
              {
                "question": "<strong>Câu 1:</strong> Hạt nhân ^60_27Co có bao nhiêu proton và neutron?",
                "solution": "<p><strong>Giải:</strong></p><p>Z = 27 proton</p><p>N = 60 - 27 = 33 neutron</p>"
              }
            ]
          },
          {
            "id": "dang2",
            "name": "Dạng 2: Bài tập phóng xạ",
            "method": "<p><strong>Phương pháp:</strong></p><ul><li>N = N₀.2^(-t/T)</li><li>A = A₀.2^(-t/T)</li></ul>",
            "examples": [
              {
                "question": "<strong>Câu 2:</strong> Chất phóng xạ có T = 15 năm. Sau 30 năm, còn bao nhiêu %?",
                "solution": "<p><strong>Giải:</strong></p><p>t/T = 30/15 = 2</p><p>N/N₀ = 2^(-2) = 1/4 = 25%</p>"
