---
import Layout from '../layouts/Layout.astro';
import { db } from '../services/db';
import { supabase, createAdminSupabase, isMockMode } from '../lib/supabase';

export const prerender = false;

const user = Astro.locals.user;

const allExams    = await db.getExams();
const subjects    = await db.getSubjects();

// Fetch creators
let creatorMap: Record<string, string> = {};
if (isMockMode) {
  creatorMap = {
    'mock-user-teacher': 'Trần Thị Giáo Viên',
    'mock-user-admin': 'Lê Hoàng Admin'
  };
} else {
  const creatorIds = [...new Set(allExams.map(e => e.created_by).filter(Boolean))] as string[];
  if (creatorIds.length > 0) {
    const adminClient = createAdminSupabase(Astro.locals.runtimeEnv) || supabase;
    const { data: users } = await adminClient.from('users').select('id, fullname').in('id', creatorIds);
    if (users) {
      users.forEach(u => { creatorMap[u.id] = u.fullname || 'Giáo viên'; });
    }
  }
}

// URL filter params
const url         = new URL(Astro.request.url);
const filterSub   = url.searchParams.get('mon')  || '';
const filterType  = url.searchParams.get('loai') || '';
const filterQ     = url.searchParams.get('q')    || '';

const filteredExams = allExams.filter(exam => {
  const matchSub  = !filterSub  || exam.subject_id === filterSub;
  const matchType = !filterType || exam.exam_type  === filterType;
  const matchQ    = !filterQ    || exam.title.toLowerCase().includes(filterQ.toLowerCase());
  return matchSub && matchType && matchQ;
});

const examTypeMeta: Record<string, { label: string; badge: string; icon: string }> = {
  '15m':       { label: 'Kiểm tra 15 phút', badge: 'bg-sky-50 text-sky-600 border-sky-100', icon: '⏱️'  },
  '45m':       { label: 'Kiểm tra 1 tiết',  badge: 'bg-amber-50 text-amber-600 border-amber-100', icon: '📝'  },
  'semester':  { label: 'Thi học kỳ',        badge: 'bg-violet-50 text-violet-600 border-violet-100', icon: '🎓'  },
  'mock_thpt': { label: 'Thi thử THPT',      badge: 'bg-rose-50 text-rose-600 border-rose-100', icon: '🏆'  },
};

// Stats
const typeCount = (t: string) => allExams.filter(e => e.exam_type === t).length;

const bgColors = [
  'bg-sky-50/80',      // xanh lơ
  'bg-rose-50/80',     // hồng nhạt
  'bg-amber-50/80',    // vàng nhạt
  'bg-violet-50/80',   // tím nhạt
  'bg-emerald-50/80',  // xanh lục nhạt
  'bg-cyan-50/80',     // xanh cyan nhạt
  'bg-orange-50/80',    // cam nhạt
  'bg-fuchsia-50/80'   // hồng tím nhạt
];
const getBgColor = (str: string) => {
  let hash = 0;
  for (let i = 0; i < str.length; i++) hash = str.charCodeAt(i) + ((hash << 5) - hash);
  return bgColors[Math.abs(hash) % bgColors.length];
};
---

<Layout
  title="Đề Thi Trắc Nghiệm Online"
  showSidebar={false}
  description="Kho đề thi trắc nghiệm lớp 12 chuẩn cấu trúc mới — Kiểm tra 15p, 1 tiết, Học kỳ và Thi thử THPT Quốc gia. Bấm giờ, chấm điểm tức thì."
>
  <!-- ===== HERO BANNER ===== -->
  <div class="relative rounded-3xl overflow-hidden mb-10 py-10 px-6 md:px-12 border border-emerald-200/40">
    <div class="absolute inset-0 bg-gradient-to-br from-emerald-50 via-teal-50/60 to-cyan-50"></div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-emerald-400/40 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-cyan-400/20 to-transparent"></div>
    <div class="absolute -top-10 -right-10 w-64 h-64 bg-emerald-400/10 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-10 -left-10 w-64 h-64 bg-cyan-400/10 rounded-full blur-3xl"></div>

    <div class="relative z-10 max-w-3xl">
      <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-semibold bg-emerald-500/10 text-emerald-700 border border-emerald-500/20 backdrop-blur-sm mb-4">
        <span class="flex h-2 w-2 relative">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
        </span>
        Bấm giờ tự động · Chấm điểm tức thì · Xem đáp án chi tiết
      </span>

      <h1 class="font-serif text-3xl md:text-4xl font-bold text-ink leading-tight mb-3">
        Kho Đề Thi Trắc Nghiệm
        <span class="block mt-1 bg-gradient-to-r from-emerald-600 via-teal-500 to-cyan-600 bg-clip-text text-transparent">
          Chuẩn Cấu Trúc Mới 2025
        </span>
      </h1>
      <p class="text-sm md:text-base text-[#8A7E72] max-w-2xl leading-relaxed">
        Luyện tập {allExams.length} đề thi đa dạng từ Kiểm tra nhanh đến Thi thử THPT Quốc gia — đầy đủ 11 môn học, tính giờ tự động.
      </p>

      <!-- Type quick stats -->
      <div class="flex flex-wrap gap-3 mt-5">
        {Object.entries(examTypeMeta).map(([type, m]) => (
          <span class={`inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-xs font-semibold border ${m.badge}`}>
            {m.icon} {m.label}
            <span class="ml-1 opacity-70">({typeCount(type)})</span>
          </span>
        ))}
      </div>
    </div>
  </div>

  <!-- ===== FILTER BAR ===== -->
  <form method="GET" action="/de-thi" class="flex flex-col sm:flex-row gap-3 mb-8" id="filter-form">
    <!-- Search -->
    <div class="relative flex-1">
      <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/>
      </svg>
      <input
        type="text"
        name="q"
        value={filterQ}
        placeholder="Tìm kiếm đề thi..."
        class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-slate-200 bg-white text-sm text-ink focus:outline-none focus:border-emerald-400 transition-colors"
      />
    </div>

    <!-- Subject filter -->
    <select
      name="mon"
      onchange="this.form.submit()"
      class="px-4 py-2.5 rounded-xl border border-slate-200 bg-white text-sm text-ink focus:outline-none focus:border-emerald-400 transition-colors cursor-pointer"
    >
      <option value="">Tất cả môn học</option>
      {subjects.map(s => (
        <option value={s.id} selected={filterSub === s.id}>{s.name}</option>
      ))}
    </select>

    <!-- Type filter -->
    <select
      name="loai"
      onchange="this.form.submit()"
      class="px-4 py-2.5 rounded-xl border border-slate-200 bg-white text-sm text-ink focus:outline-none focus:border-emerald-400 transition-colors cursor-pointer"
    >
      <option value="">Tất cả loại đề</option>
      {Object.entries(examTypeMeta).map(([val, m]) => (
        <option value={val} selected={filterType === val}>{m.icon} {m.label}</option>
      ))}
    </select>

    <!-- Search submit & Clear -->
    <div class="flex gap-2">
      <button
        type="submit"
        class="px-5 py-2.5 rounded-xl bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold shadow shadow-emerald-600/15 transition-all duration-150"
      >
        Lọc
      </button>
      {(filterSub || filterType || filterQ) && (
        <a
          href="/de-thi"
          class="px-4 py-2.5 rounded-xl border border-slate-200 text-sm font-semibold text-slate-500 hover:bg-slate-50 transition-colors"
        >
          Xóa lọc
        </a>
      )}
    </div>
  </form>

  <!-- ===== RESULTS COUNT ===== -->
  <div class="flex items-center justify-between mb-5">
    <p class="text-sm text-[#8A7E72]">
      Hiển thị <span class="font-bold text-ink">{filteredExams.length}</span> đề thi
      {(filterSub || filterType || filterQ) && <span class="text-emerald-600"> (đã lọc)</span>}
    </p>
    {user && (user.role === 'admin' || user.role === 'teacher') && (
      <a
        href="/admin/exams/new"
        class="inline-flex items-center gap-1.5 px-4 py-2 rounded-xl bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold shadow shadow-blue-600/15 transition-all"
      >
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
        </svg>
        Tạo đề thi mới
      </a>
    )}
  </div>

  <!-- ===== EXAM GRID ===== -->
  {filteredExams.length === 0 ? (
    <div class="text-center py-20 space-y-3">
      <div class="text-5xl">📭</div>
      <p class="text-lg font-bold text-ink">Không tìm thấy đề thi phù hợp</p>
      <p class="text-sm text-[#8A7E72]">Thử thay đổi bộ lọc hoặc từ khóa tìm kiếm.</p>
      <a href="/de-thi" class="inline-flex items-center gap-1 text-sm font-semibold text-emerald-600 hover:underline mt-2">
        Xem tất cả đề thi →
      </a>
    </div>
  ) : (
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {filteredExams.map(exam => {
        const typeMeta = examTypeMeta[exam.exam_type] || examTypeMeta['mock_thpt'];
        const subject  = subjects.find(s => s.id === exam.subject_id);
        const bgColor = getBgColor(exam.created_by || 'default-creator');
        const creatorName = exam.created_by ? creatorMap[exam.created_by] : null;

        return (
          <div class={`border border-slate-200/80 rounded-2xl flex flex-col justify-between overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group relative ${bgColor}`}>
            <!-- Shimmer line -->
            <div class="absolute top-0 left-8 right-8 h-0.5 bg-gradient-to-r from-transparent via-emerald-500/50 to-transparent rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-400"></div>

            <!-- Card header with type badge -->
            <div class="p-5 flex-1 bg-white/40 backdrop-blur-sm">
              <div class="flex items-start justify-between gap-3 mb-3">
                <span class={`inline-flex items-center gap-1 px-2.5 py-1 rounded-lg text-xs font-bold border bg-white ${typeMeta.badge}`}>
                  {typeMeta.icon} {typeMeta.label}
                </span>
                {exam.password && (
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-lg text-[10px] font-bold bg-white text-slate-500 border border-slate-200 shadow-sm">
                    🔒 Mật khẩu
                  </span>
                )}
              </div>

              <h1 class="text-xl font-bold text-blue-800 dark:text-blue-300 font-serif leading-snug line-clamp-2 group-hover:text-emerald-700 dark:group-hover:text-emerald-400 transition-colors">
                {exam.title}
              </h1>

              <div class="flex flex-col gap-1 mt-2.5">
                {subject && (
                  <p class="text-xs font-bold text-red-700 flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                    </svg>
                    {subject.name}
                  </p>
                )}
                {creatorName && (
                  <p class="text-[11px] font-medium text-slate-600 flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                    Tạo bởi: <span class="font-semibold text-slate-700">{creatorName}</span>
                  </p>
                )}
              </div>
            </div>

            <!-- Card footer -->
            <div class="px-5 pb-5 pt-3 border-t border-slate-200/50 flex items-center justify-between gap-3 bg-white/40 backdrop-blur-sm">
              <div class="flex items-center gap-1.5 text-xs font-bold text-slate-600">
                <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                {exam.duration} phút
              </div>

              <a
                href={`/exams/${exam.slug || exam.id}`}
                class="inline-flex items-center gap-1.5 px-4 py-2 rounded-xl bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-bold shadow shadow-emerald-600/20 hover:shadow-emerald-600/30 transition-all duration-150"
              >
                Vào thi
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                </svg>
              </a>
            </div>
          </div>
        );
      })}
    </div>
  )}

  <!-- ===== CTA FOR GUESTS ===== -->
  {!user && (
    <div class="mt-12 rounded-2xl p-8 text-center bg-gradient-to-br from-emerald-50 to-teal-50 dark:from-emerald-950/20 dark:to-teal-950/20 border border-emerald-200/50 dark:border-emerald-900/30">
      <div class="text-3xl mb-3">🎯</div>
      <h2 class="text-xl font-bold text-ink dark:text-[#E8E0D0] font-serif mb-2">Đăng ký để lưu kết quả thi</h2>
      <p class="text-sm text-[#8A7E72] dark:text-[#8A8A9E] max-w-md mx-auto mb-5">
        Tạo tài khoản miễn phí để theo dõi lịch sử làm bài, xem lại điểm số và nhận gợi ý ôn tập cá nhân từ AI.
      </p>
      <div class="flex items-center justify-center gap-4">
        <a href="/register" class="px-6 py-2.5 rounded-xl bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-bold shadow shadow-emerald-600/15 transition-all">
          Đăng ký miễn phí
        </a>
        <a href="/login" class="px-6 py-2.5 rounded-xl border border-emerald-200 dark:border-emerald-800 text-emerald-700 dark:text-emerald-400 text-sm font-semibold hover:bg-emerald-50 dark:hover:bg-emerald-950/30 transition-colors">
          Đăng nhập
        </a>
      </div>
    </div>
  )}

</Layout>
