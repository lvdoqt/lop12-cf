---
import Layout from '../../layouts/Layout.astro';
import { db } from '../../services/db';

export const prerender = false;

const user = Astro.locals.user;
const subjects = await db.getSubjects();

const subjectFilter = Astro.url.searchParams.get('mon') || '';
const courses = await db.getCourses({ 
  publishedOnly: true, 
  subjectId: subjectFilter || undefined 
});

// For enrolled users, mark which courses they're in
const enrolledCourseIds = new Set<string>();
if (user) {
  const enrollments = await db.getUserEnrollments(user.id);
  enrollments.forEach(e => enrolledCourseIds.add(e.course_id));
}

const subjectMap: Record<string, string> = {};
subjects.forEach(s => subjectMap[s.id] = s.name);
---

<Layout 
  title="Khóa học Lớp 12 - Lop12.com"
  description="Khám phá các khóa học lớp 12 chất lượng cao, giúp bạn ôn luyện và chinh phục kỳ thi THPT Quốc gia."
>
  <div class="space-y-8">
    <!-- Hero -->
    <div class="text-center py-8">
      <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white tracking-tight mb-3">
        Khóa học Lớp 12
      </h1>
      <p class="text-gray-500 dark:text-slate-400 max-w-xl mx-auto">
        Học theo lộ trình, đánh dấu tiến độ và chinh phục kỳ thi THPT Quốc gia cùng đội ngũ giáo viên chuyên nghiệp.
      </p>
    </div>

    <!-- Filter by subject -->
    <div class="flex flex-wrap gap-2 justify-center">
      <a 
        href="/khoa-hoc" 
        class={`px-4 py-2 rounded-full text-sm font-semibold transition ${!subjectFilter ? 'bg-blue-600 text-white shadow shadow-blue-500/25' : 'bg-white dark:bg-slate-900 border border-gray-200 dark:border-slate-700 text-gray-600 dark:text-slate-300 hover:border-blue-300 dark:hover:border-blue-700'}`}
      >
        Tất cả môn
      </a>
      {subjects.map(s => (
        <a 
          href={`/khoa-hoc?mon=${s.id}`}
          class={`px-4 py-2 rounded-full text-sm font-semibold transition ${subjectFilter === s.id ? 'bg-blue-600 text-white shadow shadow-blue-500/25' : 'bg-white dark:bg-slate-900 border border-gray-200 dark:border-slate-700 text-gray-600 dark:text-slate-300 hover:border-blue-300 dark:hover:border-blue-700'}`}
        >
          {s.name}
        </a>
      ))}
    </div>

    <!-- Courses Grid -->
    {courses.length === 0 ? (
      <div class="text-center py-20">
        <div class="w-16 h-16 bg-gray-50 dark:bg-slate-800 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
        </div>
        <p class="text-gray-400 dark:text-slate-500">Chưa có khóa học nào cho môn này.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {courses.map(course => {
          const enrolled = enrolledCourseIds.has(course.id);
          return (
            <a href={`/khoa-hoc/${course.slug}`} class="group bg-white dark:bg-slate-900 border border-gray-200 dark:border-slate-800 rounded-2xl overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col">
              <!-- Cover -->
              <div class="h-40 bg-gradient-to-br from-blue-500 to-indigo-600 relative overflow-hidden">
                {course.cover_url ? (
                  <img src={course.cover_url} alt={course.title} class="w-full h-full object-cover" />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center opacity-20">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-20 w-20 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                    </svg>
                  </div>
                )}
                {enrolled && (
                  <div class="absolute top-3 right-3 bg-emerald-500 text-white text-xs font-bold px-2.5 py-1 rounded-full">
                    Đã đăng ký
                  </div>
                )}
                <div class="absolute bottom-3 left-3">
                  <span class="bg-white/20 backdrop-blur-sm text-white text-xs font-semibold px-2.5 py-1 rounded-full">
                    {course.subject?.name || 'Chung'}
                  </span>
                </div>
              </div>

              <!-- Content -->
              <div class="p-5 flex flex-col flex-1">
                <h3 class="font-bold text-gray-900 dark:text-white text-base leading-snug mb-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors line-clamp-2">
                  {course.title}
                </h3>
                <p class="text-sm text-gray-500 dark:text-slate-400 line-clamp-2 mb-3 flex-1">{course.description}</p>

                <!-- Teacher -->
                {course.teacher && (
                  <div class="flex items-center gap-2 mb-3">
                    <img
                      src={course.teacher.avatar_url || `https://api.dicebear.com/7.x/adventurer/svg?seed=${course.teacher.fullname || 'teacher'}`}
                      alt={course.teacher.fullname || ''}
                      class="w-6 h-6 rounded-full object-cover bg-gray-200 dark:bg-slate-700"
                    />
                    <span class="text-xs text-gray-600 dark:text-slate-300 truncate">{course.teacher.fullname || 'Giáo viên'}</span>
                  </div>
                )}

                <div class="flex items-center justify-between text-xs text-gray-400 dark:text-slate-500 pt-3 border-t border-gray-100 dark:border-slate-800">
                  <span class="flex items-center gap-1">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
                    {course.lessonCount ?? 0} bài giảng
                  </span>
                  <span class={`font-semibold ${enrolled ? 'text-emerald-600 dark:text-emerald-400' : 'text-blue-600 dark:text-blue-400'}`}>
                    {enrolled ? 'Tiếp tục học →' : 'Xem chi tiết →'}
                  </span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    )}
  </div>
</Layout>
