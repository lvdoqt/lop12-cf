---
import Layout from '../../../../layouts/Layout.astro';
import { db } from '../../../../services/db';

export const prerender = false;

const { id } = Astro.params;
if (!id) {
  return Astro.redirect('/admin/exams');
}

const user = Astro.locals.user;
if (!user || (user.role !== 'admin' && user.role !== 'teacher')) {
  return Astro.redirect('/dashboard');
}

const exam = await db.getExamById(id);
if (!exam) {
  return Astro.redirect('/admin/exams');
}

let errMsg = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const title = formData.get('title') as string;
    const duration = Number(formData.get('duration'));
    const subject_id = formData.get('subject_id') as string;
    const category_id = (formData.get('category_id') as string) || null;
    const exam_type = formData.get('exam_type') as '15m' | '45m' | 'semester' | 'mock_thpt';
    
    const questionsJson = formData.get('questions_json') as string;
    let questionsData: any[] = [];
    
    if (questionsJson) {
      const parsed = JSON.parse(questionsJson);
      if (Array.isArray(parsed)) {
        questionsData = parsed.map(q => {
          const alphabet = ['A', 'B', 'C', 'D', 'E', 'F', 'G', 'H'];
          let options: string[] = [];
          let correctLetters: string[] = [];
          if (q.answers && Array.isArray(q.answers)) {
            q.answers.forEach((ans: any, idx: number) => {
              options.push(ans.content);
              if (ans.is_correct) {
                correctLetters.push(alphabet[idx] || String(idx));
              }
            });
          }
          return {
            content: q.content,
            options: options,
            answer: q.type === 'sa' || q.type === 'tl' ? q.answer : correctLetters.join(','),
            metadata: {
              ...(q.metadata || {}),
              type: q.type,
              difficulty: q.difficulty,
              // Make sure we keep the parent_id to identify where this question came from
              parent_id: q.metadata?.parent_id || q.id,
              ...(category_id ? { category_id } : {})
            },
            type: q.type,
            difficulty: q.difficulty
          };
        });
      }
    }

    if (!title || !duration || !subject_id || !exam_type) {
      throw new Error('Tiêu đề, Thời gian, Môn học và Phân loại đề thi là bắt buộc.');
    }

    if (questionsData.length === 0) {
      throw new Error('Cậu cần gán ít nhất một câu hỏi vào đề thi này.');
    }

    await db.updateExamWithQuestions(exam.id, {
      title,
      duration,
      subject_id,
      category_id,
      exam_type
    }, questionsData);

    return Astro.redirect('/admin/exams');

  } catch (err: any) {
    errMsg = err.message || 'Lỗi cập nhật thông tin đề thi.';
  }
}

const subjects = await db.getSubjects();
const allCategories = await db.getCategories();

// Get questions currently assigned to the exam
const assignedQuestions = await db.getQuestionsByExamId(exam.id);
const assignedQuestionIds = assignedQuestions.map(q => q.metadata?.parent_id || q.id);

// Get the teacher's (or admin's) question bank
const bankQuestions = await db.getQuestions(undefined, user.role === 'admin' ? undefined : user.id);

// Filter out questions that are already assigned
const availableQuestions = bankQuestions.filter(q => !assignedQuestionIds.includes(q.id));
---

<Layout title={`Sửa đề thi: ${exam.title}`}>
  <div class="max-w-4xl mx-auto space-y-6">
    <!-- Header -->
    <div>
      <a href="/admin/exams" class="inline-flex items-center text-xs font-bold text-gray-400 hover:text-gray-600 dark:hover:text-slate-350 transition-colors uppercase tracking-wider mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Quản lý đề thi
      </a>
      
      <h1 class="text-2xl md:text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight">Sửa đề thi</h1>
      <p class="text-sm text-gray-500 dark:text-slate-400 mt-1">Cập nhật thông tin đề thi {exam.title} và chỉnh sửa câu hỏi trực tiếp.</p>
    </div>

    <!-- Error Alert -->
    {errMsg && (
      <div class="p-4 rounded-xl bg-rose-50 text-rose-600 text-sm font-semibold border border-rose-100 dark:bg-rose-950/20 dark:text-rose-400 dark:border-rose-900/35">
        {errMsg}
      </div>
    )}

    <!-- Form -->
    <div class="bg-white dark:bg-slate-900 border border-gray-250 dark:border-slate-800/80 rounded-2xl p-6 md:p-8 shadow-sm">
      <form method="POST" id="exam-form" class="space-y-6">
        <input type="hidden" name="questions_json" id="questions_json" value="" />
        
        <!-- Exam Meta Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <!-- Title -->
          <div class="sm:col-span-2">
            <label for="title" class="block text-xs font-bold text-gray-500 dark:text-slate-400 uppercase tracking-wider mb-1.5">Tiêu đề đề thi</label>
            <input
              type="text"
              name="title"
              id="title"
              value={exam.title}
              required
              placeholder="Ví dụ: Đề thi học kỳ 1 Toán 12..."
              class="w-full px-4 py-3 rounded-xl border border-gray-250 dark:border-slate-800/80 bg-transparent text-sm focus:border-blue-500 dark:focus:border-blue-500 outline-none text-gray-800 dark:text-slate-100 transition-colors"
            />
          </div>

          <!-- Subject -->
          <div>
            <label for="subject_id" class="block text-xs font-bold text-gray-500 dark:text-slate-400 uppercase tracking-wider mb-1.5">Môn học</label>
            <select
              name="subject_id"
              id="subject_id"
              required
              class="w-full px-4 py-3 rounded-xl border border-gray-250 dark:border-slate-800/80 bg-transparent text-sm focus:border-blue-500 dark:focus:border-blue-500 outline-none text-gray-800 dark:text-slate-100"
            >
              {subjects.map(s => (
                <option value={s.id} selected={s.id === exam.subject_id}>{s.name}</option>
              ))}
            </select>
          </div>

          <!-- Category -->
          <div>
            <label for="exam_category_id" class="block text-xs font-bold text-gray-500 dark:text-slate-400 uppercase tracking-wider mb-1.5">
              Chuyên mục
              <a href="/admin/categories" target="_blank" class="ml-2 text-blue-500 hover:text-blue-700 normal-case font-semibold">➕ Quản lý</a>
            </label>
            <input type="hidden" id="exam-initial-category" value={exam.category_id || ''} />
            <select
              name="category_id"
              id="exam_category_id"
              class="w-full px-4 py-3 rounded-xl border border-gray-250 dark:border-slate-800/80 bg-transparent text-sm focus:border-blue-500 dark:focus:border-blue-500 outline-none text-gray-800 dark:text-slate-100 cursor-pointer"
            >
              <option value="">-- Không phân chuyên mục --</option>
            </select>
          </div>

          <!-- Duration -->
          <div>
            <label for="duration" class="block text-xs font-bold text-gray-500 dark:text-slate-400 uppercase tracking-wider mb-1.5">Thời gian làm bài (Phút)</label>
            <input
              type="number"
              name="duration"
              id="duration"
              value={exam.duration}
              required
              min="1"
              max="300"
              placeholder="15, 45, 90..."
              class="w-full px-4 py-3 rounded-xl border border-gray-250 dark:border-slate-800/80 bg-transparent text-sm focus:border-blue-500 dark:focus:border-blue-500 outline-none text-gray-800 dark:text-slate-100 transition-colors"
            />
          </div>

          <!-- Exam Type -->
          <div>
            <label for="exam_type" class="block text-xs font-bold text-gray-500 dark:text-slate-400 uppercase tracking-wider mb-1.5">Phân loại đề thi</label>
            <select
              name="exam_type"
              id="exam_type"
              required
              class="w-full px-4 py-3 rounded-xl border border-gray-250 dark:border-slate-800/80 bg-transparent text-sm focus:border-blue-500 dark:focus:border-blue-500 outline-none text-gray-800 dark:text-slate-100"
            >
              <option value="15m" selected={exam.exam_type === '15m'}>Kiểm tra 15 phút</option>
              <option value="45m" selected={exam.exam_type === '45m'}>Kiểm tra 1 tiết</option>
              <option value="semester" selected={exam.exam_type === 'semester'}>Thi học kỳ</option>
              <option value="mock_thpt" selected={exam.exam_type === 'mock_thpt'}>Thi thử THPT</option>
            </select>
          </div>
        </div>

        <!-- Assigned Questions -->
        <div class="border-t border-gray-100 dark:border-slate-800/60 pt-6">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h3 class="text-sm font-bold text-gray-900 dark:text-white mb-1">Câu hỏi trong đề thi</h3>
              <p class="text-xs text-gray-450 dark:text-slate-500">Các câu hỏi đang nằm trong đề thi này. Bạn có thể sửa trực tiếp hoặc xóa.</p>
            </div>
          </div>
          
          <!-- JS Render Target -->
          <div id="assigned-questions-list" class="space-y-4"></div>

          <div class="mt-4 flex flex-col sm:flex-row justify-center gap-3">
            <button
              type="button"
              id="btn-open-modal"
              class="inline-flex items-center justify-center space-x-2 px-5 py-2.5 bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 hover:bg-blue-100 dark:hover:bg-blue-900/40 rounded-xl text-sm font-bold border border-blue-200 dark:border-blue-800/50 transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 5a1 1 0 011 1v3h3a1 1 0 110 2h-3v3a1 1 0 11-2 0v-3H6a1 1 0 110-2h3V6a1 1 0 011-1z" clip-rule="evenodd" />
              </svg>
              <span>Thêm từ ngân hàng</span>
            </button>
            <button
              type="button"
              onclick="window.addEmptyQuestion()"
              class="inline-flex items-center justify-center space-x-2 px-5 py-2.5 bg-emerald-50 dark:bg-emerald-900/20 text-emerald-600 dark:text-emerald-400 hover:bg-emerald-100 dark:hover:bg-emerald-900/40 rounded-xl text-sm font-bold border border-emerald-200 dark:border-emerald-800/50 transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
              </svg>
              <span>Tạo mới tại đây</span>
            </button>
          </div>
        </div>

        <!-- Buttons -->
        <div class="flex justify-end space-x-3 pt-4 border-t border-gray-100 dark:border-slate-800/60">
          <a
            href="/admin/exams"
            class="bg-white border border-gray-250 dark:bg-slate-950 dark:border-slate-855 hover:bg-gray-50 dark:hover:bg-slate-800 text-gray-700 dark:text-slate-200 px-6 py-3 rounded-xl text-sm font-semibold transition"
          >
            Hủy
          </a>
          <button
            type="submit"
            class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-xl text-sm font-bold shadow-md shadow-blue-500/10 hover:shadow-xl transition"
          >
            Lưu và xuất bản lại
          </button>
        </div>

      </form>
    </div>
  </div>
  
  <!-- Question Bank Modal -->
  <div id="question-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-gray-900/50 dark:bg-black/60 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-200">
    <div class="bg-white dark:bg-slate-900 rounded-2xl shadow-2xl w-full max-w-4xl max-h-[90vh] flex flex-col border border-gray-200 dark:border-slate-800 transform scale-95 transition-transform duration-200" id="question-modal-content">
      
      <!-- Modal Header -->
      <div class="px-6 py-4 border-b border-gray-100 dark:border-slate-800/60 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
          <h2 class="text-xl font-bold text-gray-900 dark:text-white">Ngân hàng câu hỏi của bạn</h2>
          <p class="text-xs text-gray-500 dark:text-slate-400 mt-1">Chọn các câu hỏi để thêm vào đề thi</p>
        </div>
        <div class="flex items-center gap-3">
          <select id="modal_subject_id" class="px-3 py-1.5 rounded-lg border border-gray-250 dark:border-slate-700 bg-transparent text-sm text-gray-800 dark:text-slate-100 outline-none focus:border-blue-500">
             {subjects.map(s => <option value={s.id} selected={s.id === exam.subject_id}>{s.name}</option>)}
          </select>
          <select id="modal_category_id" class="px-3 py-1.5 rounded-lg border border-gray-250 dark:border-slate-700 bg-transparent text-sm text-gray-800 dark:text-slate-100 outline-none focus:border-blue-500">
             <option value="">-- Tất cả chuyên mục --</option>
          </select>
          <button type="button" id="btn-close-modal" class="p-2 text-gray-400 hover:text-gray-600 dark:hover:text-slate-300 hover:bg-gray-100 dark:hover:bg-slate-800 rounded-xl transition">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>
      
      <!-- Modal Body -->
      <div class="p-6 overflow-y-auto flex-1 bg-gray-50/50 dark:bg-slate-950/30">
        <div id="no-bank-questions-warning" class="text-center p-6 bg-white dark:bg-slate-900 rounded-xl text-sm text-gray-500 dark:text-slate-400 border border-dashed border-gray-200 dark:border-slate-800 hidden">
          Không có câu hỏi nào thuộc môn học này trong ngân hàng của bạn, hoặc bạn đã thêm tất cả vào đề thi.
        </div>

        <div id="bank-questions-list" class="space-y-4"></div>
      </div>
      
      <!-- Modal Footer -->
      <div class="px-6 py-4 border-t border-gray-100 dark:border-slate-800/60 bg-white dark:bg-slate-900 rounded-b-2xl flex justify-between items-center">
        <span class="text-sm font-semibold text-gray-500 dark:text-slate-400"><span id="selected-count">0</span> câu hỏi được chọn</span>
        <div class="space-x-3">
          <button type="button" id="btn-cancel-modal" class="px-5 py-2.5 rounded-xl border border-gray-250 dark:border-slate-700 text-gray-700 dark:text-slate-300 font-semibold text-sm hover:bg-gray-50 dark:hover:bg-slate-800 transition">Hủy</button>
          <button type="button" id="btn-add-selected" class="px-5 py-2.5 rounded-xl bg-blue-600 hover:bg-blue-700 text-white font-bold text-sm shadow-md transition">Tiếp tục</button>
        </div>
      </div>
      
    </div>
  </div>

</Layout>

<!-- Data payload for JS to consume -->
<script type="application/json" id="assigned-questions-data" set:html={JSON.stringify(assignedQuestions).replace(/</g, '\\u003c')}></script>
<script type="application/json" id="bank-questions-data" set:html={JSON.stringify(availableQuestions).replace(/</g, '\\u003c')}></script>

<script>
  let examQuestions = JSON.parse(document.getElementById('assigned-questions-data').textContent || '[]');
  let bankQuestions = JSON.parse(document.getElementById('bank-questions-data').textContent || '[]');
  let editingId = null;

  const subjectSelect = document.getElementById('subject_id') as HTMLSelectElement | null;
  const list = document.getElementById('assigned-questions-list');
  const bankList = document.getElementById('bank-questions-list');
  
  function escapeHtml(unsafe) {
    if (!unsafe) return '';
    return unsafe
         .replace(/&/g, "&amp;")
         .replace(/</g, "&lt;")
         .replace(/>/g, "&gt;")
         .replace(/"/g, "&quot;")
         .replace(/'/g, "&#039;");
  }

  function renderAssigned() {
    if (!list) return;
    list.innerHTML = '';
    
    if (examQuestions.length === 0) {
      list.innerHTML = '<div class="text-center p-6 bg-gray-50 dark:bg-slate-950 rounded-xl text-xs text-gray-500 dark:text-slate-450 border border-dashed border-gray-200 dark:border-slate-855">Chưa có câu hỏi nào trong đề thi này.</div>';
    } else {
      examQuestions.forEach((q, idx) => {
        const isEditing = editingId === q.id;
        const div = document.createElement('div');
        div.className = "p-4 rounded-xl border border-gray-250 dark:border-slate-800 bg-white dark:bg-slate-900";
        
        if (isEditing) {
          let answersHtml = '';
          if (q.type === 'read' || q.type === 'list') {
            const subqs = (q.metadata && q.metadata.questions) || [];
            answersHtml = '<div class="col-span-1 sm:col-span-2 space-y-4 mt-2">';
            
            if (q.type === 'list') {
               answersHtml += `
                 <div class="mb-4 space-y-1 bg-blue-50/50 dark:bg-blue-900/10 p-3 rounded-lg border border-blue-100 dark:border-blue-900/30">
                   <label class="block text-xs font-bold text-blue-600 dark:text-blue-400 uppercase">Link Audio (MP3/WAV/Gg Drive)</label>
                   <input type="url" id="edit-audio-url-${q.id}" class="w-full px-3 py-2 rounded-lg border border-gray-300 dark:border-slate-700 text-sm bg-white dark:bg-slate-900 dark:text-white focus:border-blue-500 outline-none" value="${escapeHtml(q.metadata?.audio_url || '')}" placeholder="https://domain.com/audio.mp3">
                 </div>
               `;
            }

            subqs.forEach((sq, sIdx) => {
               answersHtml += `
                 <div class="p-3 bg-gray-50 dark:bg-slate-800/50 rounded-lg border border-gray-200 dark:border-slate-700 space-y-3">
                   <div class="flex justify-between items-center"><span class="text-xs font-bold text-blue-600 dark:text-blue-400">Câu con ${sIdx + 1}</span></div>
                   <textarea class="w-full px-3 py-1.5 rounded-lg border border-gray-300 dark:border-slate-600 text-sm bg-white dark:bg-slate-900 dark:text-white focus:border-blue-500 outline-none" rows="2" id="edit-subq-content-${q.id}-${sIdx}">${escapeHtml(sq.question || sq.content)}</textarea>
                   <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mt-2">
                     <div class="flex items-center space-x-2"><input type="radio" name="correct-${q.id}-${sIdx}" value="A" ${sq.correct_option==='A'?'checked':''} class="w-4 h-4 text-blue-600 cursor-pointer"><input type="text" class="flex-1 px-2 py-1.5 rounded-lg border border-gray-300 dark:border-slate-600 text-sm bg-white dark:bg-slate-900 dark:text-white focus:border-blue-500 outline-none" id="edit-subq-a-${q.id}-${sIdx}" value="${escapeHtml(sq.option_a)}"></div>
                     <div class="flex items-center space-x-2"><input type="radio" name="correct-${q.id}-${sIdx}" value="B" ${sq.correct_option==='B'?'checked':''} class="w-4 h-4 text-blue-600 cursor-pointer"><input type="text" class="flex-1 px-2 py-1.5 rounded-lg border border-gray-300 dark:border-slate-600 text-sm bg-white dark:bg-slate-900 dark:text-white focus:border-blue-500 outline-none" id="edit-subq-b-${q.id}-${sIdx}" value="${escapeHtml(sq.option_b)}"></div>
                     <div class="flex items-center space-x-2"><input type="radio" name="correct-${q.id}-${sIdx}" value="C" ${sq.correct_option==='C'?'checked':''} class="w-4 h-4 text-blue-600 cursor-pointer"><input type="text" class="flex-1 px-2 py-1.5 rounded-lg border border-gray-300 dark:border-slate-600 text-sm bg-white dark:bg-slate-900 dark:text-white focus:border-blue-500 outline-none" id="edit-subq-c-${q.id}-${sIdx}" value="${escapeHtml(sq.option_c)}"></div>
                     <div class="flex items-center space-x-2"><input type="radio" name="correct-${q.id}-${sIdx}" value="D" ${sq.correct_option==='D'?'checked':''} class="w-4 h-4 text-blue-600 cursor-pointer"><input type="text" class="flex-1 px-2 py-1.5 rounded-lg border border-gray-300 dark:border-slate-600 text-sm bg-white dark:bg-slate-900 dark:text-white focus:border-blue-500 outline-none" id="edit-subq-d-${q.id}-${sIdx}" value="${escapeHtml(sq.option_d)}"></div>
                   </div>
                 </div>
               `;
            });
            answersHtml += `
              <button type="button" onclick="window.addSubQ('${q.id}')" class="text-xs font-bold text-blue-600 bg-blue-50 px-3 py-1.5 rounded hover:bg-blue-100 transition">+ Thêm câu con</button>
            </div>`;
          } else if (q.type === 'sa' || q.type === 'tl') {
            answersHtml = `
              <div class="col-span-1 sm:col-span-2">
                <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Câu trả lời đúng</label>
                <input type="text" id="edit-sa-answer-${q.id}" class="w-full px-3 py-2 rounded-lg border border-gray-300 dark:border-slate-700 text-sm bg-transparent dark:text-white focus:border-blue-500 outline-none" value="${escapeHtml(q.answer || '')}" placeholder="Nhập đáp án...">
              </div>
            `;
          } else if (q.answers && q.answers.length > 0) {
            const inputType = (q.type === 'msq' || q.type === 'multiple_choice') ? 'checkbox' : 'radio';
            answersHtml = q.answers.map((a, aIdx) => `
              <div class="flex items-center space-x-2">
                <input type="${inputType}" name="correct-${q.id}" value="${aIdx}" ${a.is_correct ? 'checked' : ''} class="w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 rounded focus:ring-blue-500 dark:focus:ring-blue-600 dark:ring-offset-gray-800 dark:bg-gray-700 dark:border-gray-600 cursor-pointer">
                <input type="text" class="flex-1 px-3 py-1.5 rounded-lg border border-gray-300 dark:border-slate-700 text-sm bg-transparent dark:text-white focus:border-blue-500 outline-none" value="${escapeHtml(a.content)}" id="edit-ans-${q.id}-${aIdx}">
              </div>
            `).join('');
          } else {
            answersHtml = `<p class="text-xs text-gray-500 italic">Câu hỏi này không có đáp án trắc nghiệm.</p>`;
          }

          div.innerHTML = `
            <div class="space-y-3">
              <div class="flex flex-col sm:flex-row justify-between sm:items-center gap-2 mb-2">
                <span class="text-sm font-bold text-blue-600 dark:text-blue-400">Đang sửa câu ${idx + 1}</span>
                <select class="px-2 py-1.5 border border-blue-200 dark:border-blue-800 rounded-lg text-xs bg-blue-50 dark:bg-blue-900/30 text-blue-800 dark:text-blue-200 font-semibold outline-none focus:ring-2 focus:ring-blue-500 cursor-pointer" onchange="window.changeType('${q.id}', this.value)">
                   <option value="single_choice" ${q.type==='single_choice'?'selected':''}>Trắc nghiệm 1 lựa chọn</option>
                   <option value="multiple_choice" ${q.type==='multiple_choice'?'selected':''}>Trắc nghiệm nhiều lựa chọn</option>
                   <option value="msq" ${q.type==='msq'?'selected':''}>Trắc nghiệm Đúng / Sai</option>
                   <option value="sa" ${q.type==='sa'?'selected':''}>Trả lời ngắn</option>
                   <option value="tl" ${q.type==='tl'?'selected':''}>Tự luận</option>
                   <option value="read" ${q.type==='read'?'selected':''}>Đọc hiểu</option>
                   <option value="list" ${q.type==='list'?'selected':''}>Nghe</option>
                </select>
              </div>
              <textarea class="w-full px-3 py-2 rounded-lg border border-gray-300 dark:border-slate-700 text-sm bg-transparent dark:text-white focus:border-blue-500 outline-none" rows="4" id="edit-content-${q.id}">${escapeHtml(q.content)}</textarea>
              
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-3">
                ${answersHtml}
              </div>
              
              <div class="flex justify-end space-x-2 mt-4 pt-3 border-t border-gray-100 dark:border-slate-800">
                <button type="button" class="px-4 py-2 text-xs font-bold bg-gray-100 hover:bg-gray-200 dark:bg-slate-800 dark:hover:bg-slate-700 text-gray-700 dark:text-slate-300 rounded-lg transition" onclick="window.cancelEdit()">Hủy</button>
                <button type="button" class="px-4 py-2 text-xs font-bold bg-blue-600 hover:bg-blue-700 text-white rounded-lg shadow transition" onclick="window.saveEdit('${q.id}')">Lưu nội dung</button>
              </div>
            </div>
          `;
        } else {
          let answersHtml = '';
          if (q.type === 'read' || q.type === 'list') {
            const subqs = (q.metadata && q.metadata.questions) || [];
            answersHtml = '<div class="col-span-1 sm:col-span-2 space-y-3 mt-2">';
            
            if (q.type === 'list' && q.metadata?.audio_url) {
               answersHtml += `
                 <div class="mb-2">
                   <a href="${escapeHtml(q.metadata.audio_url)}" target="_blank" class="inline-flex items-center space-x-1.5 px-3 py-1.5 bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 rounded-lg text-xs font-bold hover:bg-blue-100 dark:hover:bg-blue-900/50 transition">
                     <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                       <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
                     </svg>
                     <span>Mở file Audio</span>
                   </a>
                 </div>
               `;
            }

            subqs.forEach((sq, sIdx) => {
               answersHtml += `
                 <div class="p-3 bg-gray-50 dark:bg-slate-800/30 rounded-lg border border-gray-100 dark:border-slate-700/50">
                   <p class="text-sm font-semibold mb-2 text-gray-800 dark:text-slate-200">Câu ${idx + 1}.${sIdx + 1}: ${escapeHtml(sq.question || sq.content)}</p>
                   <ul class="text-xs space-y-1.5 grid grid-cols-1 sm:grid-cols-2 gap-1">
                     <li class="flex gap-1 p-1.5 rounded ${sq.correct_option === 'A' ? 'bg-emerald-50 text-emerald-700 font-bold dark:bg-emerald-900/20 dark:text-emerald-400' : 'text-gray-600 dark:text-slate-400'}"><span class="w-4 shrink-0">A.</span><span class="truncate">${escapeHtml(sq.option_a)}</span></li>
                     <li class="flex gap-1 p-1.5 rounded ${sq.correct_option === 'B' ? 'bg-emerald-50 text-emerald-700 font-bold dark:bg-emerald-900/20 dark:text-emerald-400' : 'text-gray-600 dark:text-slate-400'}"><span class="w-4 shrink-0">B.</span><span class="truncate">${escapeHtml(sq.option_b)}</span></li>
                     <li class="flex gap-1 p-1.5 rounded ${sq.correct_option === 'C' ? 'bg-emerald-50 text-emerald-700 font-bold dark:bg-emerald-900/20 dark:text-emerald-400' : 'text-gray-600 dark:text-slate-400'}"><span class="w-4 shrink-0">C.</span><span class="truncate">${escapeHtml(sq.option_c)}</span></li>
                     <li class="flex gap-1 p-1.5 rounded ${sq.correct_option === 'D' ? 'bg-emerald-50 text-emerald-700 font-bold dark:bg-emerald-900/20 dark:text-emerald-400' : 'text-gray-600 dark:text-slate-400'}"><span class="w-4 shrink-0">D.</span><span class="truncate">${escapeHtml(sq.option_d)}</span></li>
                   </ul>
                 </div>
               `;
            });
            answersHtml += '</div>';
          } else if (q.answers && q.answers.length > 0) {
            answersHtml = q.answers.map((a, aIdx) => `
              <div class="flex items-start gap-2 p-2 rounded-lg border text-xs ${a.is_correct ? 'bg-emerald-50 border-emerald-200 text-emerald-800 dark:bg-emerald-900/20 dark:border-emerald-800/50 dark:text-emerald-300' : 'bg-gray-50 border-gray-100 text-gray-600 dark:bg-slate-800/50 dark:border-slate-700 dark:text-slate-400'}">
                <span class="font-bold shrink-0">${String.fromCharCode(65 + aIdx)}.</span>
                <span class="leading-snug">${escapeHtml(a.content)}</span>
              </div>
            `).join('');
          }

          div.innerHTML = `
            <div class="text-sm font-medium flex-1">
              <div class="flex justify-between items-start">
                <p class="text-gray-900 dark:text-white font-bold leading-relaxed whitespace-pre-wrap flex-1 pr-4">
                  <span class="text-blue-600 dark:text-blue-400 mr-1">Câu ${idx + 1}:</span>
                  ${escapeHtml(q.content)}
                </p>
                <div class="flex space-x-1 shrink-0">
                  <button type="button" class="text-blue-500 hover:bg-blue-50 dark:hover:bg-blue-900/30 p-1.5 rounded-lg transition" title="Sửa trực tiếp" onclick="window.startEdit('${q.id}')">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                      <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
                    </svg>
                  </button>
                  <button type="button" class="text-rose-500 hover:bg-rose-50 dark:hover:bg-rose-950/30 p-1.5 rounded-lg transition" title="Xóa khỏi đề thi" onclick="window.removeQuestion('${q.id}')">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
                    </svg>
                  </button>
                </div>
              </div>
              <div class="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-2">
                ${answersHtml}
              </div>
            </div>
          `;
        }
        list.appendChild(div);
      });
    }
    
    // Update hidden input for form POST
    const questionsInput = document.getElementById('questions_json') as HTMLInputElement;
    if (questionsInput) {
      questionsInput.value = JSON.stringify(examQuestions);
    }
  }

  function renderBank() {
    if (!bankList) return;
    const modalSubject = document.getElementById('modal_subject_id') as HTMLSelectElement | null;
    const modalCategory = document.getElementById('modal_category_id') as HTMLSelectElement | null;
    const selectedSubjectId = modalSubject?.value;
    const selectedCategoryId = modalCategory?.value;
    
    const warning = document.getElementById('no-bank-questions-warning');
    let visibleCount = 0;
    bankList.innerHTML = '';

    bankQuestions.forEach(q => {
      // Filter by subject and ensure it's not already in examQuestions (by original bank id)
      // examQuestion.metadata?.parent_id is the bank question ID
      const isAlreadyInExam = examQuestions.some(eq => (eq.metadata?.parent_id || eq.id) === q.id);
      
      let matches = q.subject_id === selectedSubjectId && !isAlreadyInExam;
      if (matches && selectedCategoryId) {
        matches = matches && (q.metadata?.category_id === selectedCategoryId);
      }
      
      if (matches) {
        visibleCount++;
        const label = document.createElement('label');
        label.className = "flex items-start space-x-4 p-4 rounded-xl border border-gray-250 dark:border-slate-800 bg-white dark:bg-slate-900 hover:border-blue-300 dark:hover:border-blue-800 transition cursor-pointer";
        
        let answersHtml = '';
        if (q.type === 'read' || q.type === 'list') {
            const subqs = (q.metadata && q.metadata.questions) || [];
            answersHtml = '<div class="col-span-1 sm:col-span-2 space-y-2 mt-1">';
            subqs.forEach((sq, sIdx) => {
               answersHtml += `
                 <div class="p-2 bg-gray-50 dark:bg-slate-800/30 rounded border border-gray-100 dark:border-slate-700/50">
                   <p class="text-xs font-semibold mb-1 text-gray-700 dark:text-slate-300">Câu con ${sIdx + 1}: ${escapeHtml(sq.question || sq.content)}</p>
                 </div>
               `;
            });
            answersHtml += '</div>';
        } else if (q.answers && q.answers.length > 0) {
          answersHtml = q.answers.map((a, aIdx) => `
            <div class="flex items-start gap-2 p-2 rounded-lg border text-xs ${a.is_correct ? 'bg-emerald-50 border-emerald-200 text-emerald-800 dark:bg-emerald-900/20 dark:border-emerald-800/50 dark:text-emerald-300' : 'bg-gray-50 border-gray-100 text-gray-600 dark:bg-slate-800/50 dark:border-slate-700 dark:text-slate-400'}">
              <span class="font-bold shrink-0">${String.fromCharCode(65 + aIdx)}.</span>
              <span class="leading-snug">${escapeHtml(a.content)}</span>
            </div>
          `).join('');
        }

        label.innerHTML = `
          <input type="checkbox" value="${q.id}" class="modal-question-checkbox rounded text-blue-600 focus:ring-blue-500 h-5 w-5 mt-1 shrink-0 cursor-pointer" />
          <div class="text-sm font-medium flex-1">
            <p class="text-gray-900 dark:text-white font-bold leading-relaxed whitespace-pre-wrap">${escapeHtml(q.content)}</p>
            <div class="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-2">
              ${answersHtml}
            </div>
          </div>
        `;
        bankList.appendChild(label);
      }
    });

    if (warning) {
      if (visibleCount === 0) warning.classList.remove('hidden');
      else warning.classList.add('hidden');
    }

    updateSelectedCount();
    
    // Attach change listeners to new checkboxes
    document.querySelectorAll('.modal-question-checkbox').forEach(cb => {
      cb.addEventListener('change', updateSelectedCount);
    });
  }

  // Edit Actions
  window.startEdit = (id) => { editingId = id; renderAssigned(); };
  window.cancelEdit = () => { editingId = null; renderAssigned(); };
  window.saveEdit = (id) => {
    const q = examQuestions.find(x => x.id === id);
    if (!q) return;
    q.content = document.getElementById(`edit-content-${id}`).value;
    
    if (q.type === 'read' || q.type === 'list') {
      const subqs = q.metadata.questions || [];
      subqs.forEach((sq, sIdx) => {
         const subContent = document.getElementById(`edit-subq-content-${id}-${sIdx}`);
         if (subContent) sq.question = subContent.value;
         const subA = document.getElementById(`edit-subq-a-${id}-${sIdx}`);
         if (subA) sq.option_a = subA.value;
         const subB = document.getElementById(`edit-subq-b-${id}-${sIdx}`);
         if (subB) sq.option_b = subB.value;
         const subC = document.getElementById(`edit-subq-c-${id}-${sIdx}`);
         if (subC) sq.option_c = subC.value;
         const subD = document.getElementById(`edit-subq-d-${id}-${sIdx}`);
         if (subD) sq.option_d = subD.value;
         const radio = document.querySelector(`input[name="correct-${id}-${sIdx}"]:checked`);
         if (radio) sq.correct_option = radio.value;
      });
      if (q.type === 'list') {
        const audioUrlInput = document.getElementById(`edit-audio-url-${id}`);
        if (audioUrlInput) q.metadata.audio_url = audioUrlInput.value;
      }
    } else if (q.type === 'sa' || q.type === 'tl') {
      const saInput = document.getElementById(`edit-sa-answer-${id}`);
      if (saInput) q.answer = saInput.value;
    } else if (q.answers && q.answers.length > 0) {
      q.answers.forEach((a, aIdx) => {
        a.content = document.getElementById(`edit-ans-${id}-${aIdx}`).value;
        const input = document.querySelector(`input[name="correct-${id}"][value="${aIdx}"]`);
        if (input) a.is_correct = input.checked;
      });
    }
    editingId = null;
    renderAssigned();
  };
  window.addEmptyQuestion = () => {
    // Save current editing if any
    if (editingId) window.saveEdit(editingId);

    const newId = 'new-q-' + Math.random().toString(36).substring(2, 9);
    const newQ = {
      id: newId,
      type: 'single_choice',
      difficulty: 'medium',
      content: 'Nội dung câu hỏi...',
      answers: [
        { content: 'Phương án A', is_correct: true },
        { content: 'Phương án B', is_correct: false },
        { content: 'Phương án C', is_correct: false },
        { content: 'Phương án D', is_correct: false },
      ],
      metadata: {}
    };
    examQuestions.push(newQ);
    editingId = newId;
    renderAssigned();
    setTimeout(() => {
      document.getElementById(`edit-content-${newId}`)?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      document.getElementById(`edit-content-${newId}`)?.focus();
    }, 100);
  };

  window.addSubQ = (id) => {
    const q = examQuestions.find(x => x.id === id);
    if (!q) return;
    window.saveEdit(id); // save current state first
    q.metadata = q.metadata || {};
    q.metadata.questions = q.metadata.questions || [];
    q.metadata.questions.push({
      question: 'Câu hỏi con...', option_a: 'A', option_b: 'B', option_c: 'C', option_d: 'D', correct_option: 'A'
    });
    editingId = id;
    renderAssigned();
  };

  window.changeType = (id, newType) => {
    window.saveEdit(id); // try to save current state
    const q = examQuestions.find(x => x.id === id);
    if (!q) return;
    q.type = newType;
    if (newType === 'sa' || newType === 'tl') {
      q.answers = [];
      q.answer = q.answer || '';
      if (q.metadata) delete q.metadata.questions;
    } else if (newType === 'read' || newType === 'list') {
      q.answers = [];
      q.metadata = q.metadata || {};
      if (!q.metadata.questions || q.metadata.questions.length === 0) {
        q.metadata.questions = [
          { question: 'Câu hỏi con 1...', option_a: 'A', option_b: 'B', option_c: 'C', option_d: 'D', correct_option: 'A' }
        ];
      }
      if (newType === 'list') {
        q.metadata.audio_url = q.metadata.audio_url || '';
      }
    } else {
      if (q.metadata) delete q.metadata.questions;
      if (!q.answers || q.answers.length === 0) {
        q.answers = [
          { content: 'Phương án A', is_correct: true },
          { content: 'Phương án B', is_correct: false },
          { content: 'Phương án C', is_correct: false },
          { content: 'Phương án D', is_correct: false }
        ];
      } else if (newType === 'single_choice' || newType === 'true_false') {
        // ensure only one correct
        let hasCorrect = false;
        q.answers.forEach(a => {
          if (a.is_correct && !hasCorrect) hasCorrect = true;
          else a.is_correct = false;
        });
        if (!hasCorrect && q.answers.length > 0) q.answers[0].is_correct = true;
      }
    }
    editingId = id;
    editingId = id;
    renderAssigned();
  };

  window.removeQuestion = (id) => {
    examQuestions = examQuestions.filter(x => x.id !== id);
    renderAssigned();
    renderBank(); // Make it available in bank again
  };

  // Modal logic
  const modal = document.getElementById('question-modal');
  const modalContent = document.getElementById('question-modal-content');
  const btnOpenModal = document.getElementById('btn-open-modal');
  const btnCloseModal = document.getElementById('btn-close-modal');
  const btnCancelModal = document.getElementById('btn-cancel-modal');
  const btnAddSelected = document.getElementById('btn-add-selected');
  const selectedCountEl = document.getElementById('selected-count');

  const openModal = () => {
    if (!modal || !modalContent) return;
    renderBank();
    modal.classList.remove('opacity-0', 'pointer-events-none');
    modalContent.classList.remove('scale-95');
    document.body.style.overflow = 'hidden';
  };

  const closeModal = () => {
    if (!modal || !modalContent) return;
    modal.classList.add('opacity-0', 'pointer-events-none');
    modalContent.classList.add('scale-95');
    document.body.style.overflow = '';
  };

  const updateSelectedCount = () => {
    if (!selectedCountEl) return;
    const count = document.querySelectorAll('.modal-question-checkbox:checked').length;
    selectedCountEl.textContent = count.toString();
  };

  btnOpenModal?.addEventListener('click', openModal);
  btnCloseModal?.addEventListener('click', closeModal);
  btnCancelModal?.addEventListener('click', closeModal);

  btnAddSelected?.addEventListener('click', () => {
    const checked = document.querySelectorAll('.modal-question-checkbox:checked');
    checked.forEach(cb => {
      const qId = (cb as HTMLInputElement).value;
      const bankQ = bankQuestions.find(x => x.id === qId);
      if (bankQ) {
        // Deep clone the bank question, assign a new pseudo-ID for the UI array
        const newQ = JSON.parse(JSON.stringify(bankQ));
        newQ.id = 'exam-q-' + Math.random().toString(36).substr(2, 9);
        newQ.metadata = newQ.metadata || {};
        newQ.metadata.parent_id = bankQ.id; // remember where it came from
        examQuestions.push(newQ);
      }
    });
    renderAssigned();
    closeModal();
  });

  subjectSelect?.addEventListener('change', () => {
    // Subject changed, just re-render bank next time it opens
  });

  // Category dropdown dynamic filter
  const catDataEl = document.getElementById('categories-data');
  const ALL_CATEGORIES = catDataEl ? JSON.parse(catDataEl.textContent || '[]') : [];

  function updateCategoryDropdown(subjectId: string, dropdownId: string) {
    const sel = document.getElementById(dropdownId) as HTMLSelectElement | null;
    if (!sel) return;
    const filtered = ALL_CATEGORIES.filter((c: any) => c.subject_id === subjectId);
    
    const currentVal = sel.value;
    sel.innerHTML = '<option value="">-- Không phân chuyên mục --</option>';
    filtered.forEach((c: any) => {
      const opt = document.createElement('option');
      opt.value = c.id;
      opt.textContent = c.name;
      sel.appendChild(opt);
    });
    
    if (currentVal) {
      sel.value = currentVal;
    }
  }

  // Bind change listeners to avoid inline event scope issue
  if (subjectSelect) {
    subjectSelect.addEventListener('change', () => {
      updateCategoryDropdown(subjectSelect.value, 'exam_category_id');
    });
    if (subjectSelect.value) {
      updateCategoryDropdown(subjectSelect.value, 'exam_category_id');
      const initialCat = (document.getElementById('exam-initial-category') as HTMLInputElement | null)?.value;
      const catDropdown = document.getElementById('exam_category_id') as HTMLSelectElement | null;
      if (initialCat && catDropdown) {
        catDropdown.value = initialCat;
      }
    }
  }

  const modalSubjectSelect = document.getElementById('modal_subject_id') as HTMLSelectElement | null;
  const modalCategorySelect = document.getElementById('modal_category_id') as HTMLSelectElement | null;
  if (modalSubjectSelect) {
    modalSubjectSelect.addEventListener('change', () => {
      updateCategoryDropdown(modalSubjectSelect.value, 'modal_category_id');
      renderBank();
    });
    if (modalSubjectSelect.value) {
      updateCategoryDropdown(modalSubjectSelect.value, 'modal_category_id');
    }
  }
  if (modalCategorySelect) {
    modalCategorySelect.addEventListener('change', () => {
      renderBank();
    });
  }

  // Initial render
  renderAssigned();

</script>

<script id="categories-data" type="application/json" set:html={JSON.stringify(allCategories)}></script>
