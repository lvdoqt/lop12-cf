---
import Layout from '../../../layouts/Layout.astro';
import { db } from '../../../services/db';
import ReadListPreview from '../../../components/ReadListPreview.astro';

export const prerender = false;

const user = Astro.locals.user;
if (!user || (user.role !== 'admin' && user.role !== 'teacher')) {
  return Astro.redirect('/dashboard');
}

const isAdmin = user.role === 'admin';

let successMsg = '';
let errMsg = '';

// Check for imported query param
const url = new URL(Astro.request.url);
const importedCount = url.searchParams.get('imported');
if (importedCount && parseInt(importedCount) > 0) {
  successMsg = `Đã nhập thành công ${importedCount} câu hỏi vào ngân hàng!`;
}

// Handle Delete Question (POST)
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get('action') as string;
    
    if (action === 'delete') {
      const questionId = formData.get('questionId') as string;
      if (questionId) {
        await db.deleteQuestion(questionId);
        successMsg = 'Đã xóa câu hỏi thành công khỏi ngân hàng câu hỏi!';
      }
    }
  } catch (err: any) {
    errMsg = err.message || 'Lỗi xóa câu hỏi.';
  }
}

// Fetch questions and subjects
const subjects = await db.getSubjects();
const categories = await db.getCategories();
const categoriesMap = Object.fromEntries(categories.map(c => [c.id, c]));
let questions = await db.getQuestions(undefined, user.role === 'admin' ? undefined : user.id);

const allUsers = isAdmin ? await db.getUsers() : [];
const usersMap = Object.fromEntries(allUsers.map(u => [u.id, u]));

// --- FILTERS ---
const filterSubject = url.searchParams.get('subject_id') || '';
const filterType = url.searchParams.get('type') || '';
const filterGrade = url.searchParams.get('grade') || '';
const filterCat = url.searchParams.get('category_id') || '';

if (filterSubject) {
  questions = questions.filter(q => q.subject_id === filterSubject);
}
if (filterType) {
  questions = questions.filter(q => q.type === filterType);
}
if (filterGrade) {
  questions = questions.filter(q => q.difficulty === filterGrade);
}
if (filterCat) {
  questions = questions.filter(q => q.category_id === filterCat || q.metadata?.category_id === filterCat);
}

// --- PAGINATION ---
const page = parseInt(url.searchParams.get('page') || '1') || 1;
const limit = 50;
const totalItems = questions.length;
const totalPages = Math.ceil(totalItems / limit) || 1;
const safePage = Math.max(1, Math.min(page, totalPages));
const startIndex = (safePage - 1) * limit;
const paginatedQuestions = questions.slice(startIndex, startIndex + limit);

const getSubjectName = (subjectId: string) => {
  return subjects.find(s => s.id === subjectId)?.name || 'Chưa phân loại';
};

const qTypeNames: Record<string, string> = {
  'single_choice': 'Trắc nghiệm đơn',
  'multiple_choice': 'Nhiều lựa chọn',
  'true_false': 'Đúng / Sai',
  'msq': 'Đúng / Sai (THPT)',
  'sa': 'Trả lời ngắn',
  'tl': 'Tự luận',
  'read': 'Đọc hiểu',
  'list': 'Kỹ năng nghe'
};
---

<Layout title="Ngân hàng câu hỏi">
  <div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
      <div>
        <a href="/admin" class="inline-flex items-center text-xs font-bold text-gray-400 hover:text-gray-600 dark:hover:text-slate-350 transition-colors uppercase tracking-wider mb-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          Quản trị Admin
        </a>
        
        <h1 class="text-2xl md:text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight">Ngân hàng câu hỏi</h1>
        <p class="text-sm text-gray-500 dark:text-slate-400 mt-1">Quản lý kho lưu trữ câu hỏi và các phương án trả lời lớp 12.</p>
      </div>

      <div>
        <a
          href="/admin/questions/new"
          class="inline-flex items-center justify-center bg-blue-600 hover:bg-blue-700 text-white font-semibold px-4 py-2.5 rounded-xl shadow-md shadow-blue-500/10 transition text-sm"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
          </svg>
          Thêm câu hỏi mới
        </a>
      </div>
    </div>

    <!-- Notifications -->
    {successMsg && (
      <div class="p-4 rounded-xl bg-emerald-50 text-emerald-600 text-sm font-semibold border border-emerald-100 dark:bg-emerald-950/20 dark:text-emerald-400 dark:border-emerald-900/35">
        {successMsg}
      </div>
    )}
    {errMsg && (
      <div class="p-4 rounded-xl bg-rose-50 text-rose-600 text-sm font-semibold border border-rose-100 dark:bg-rose-950/20 dark:text-rose-400 dark:border-rose-900/35">
        {errMsg}
      </div>
    )}

    <!-- Filters & Actions Bar -->
    <div class="bg-white border border-gray-250 dark:bg-slate-900 dark:border-slate-800/80 rounded-2xl p-4 shadow-sm flex flex-col md:flex-row items-center justify-between gap-4">
      <form method="GET" class="flex flex-col sm:flex-row gap-3 w-full md:w-auto items-center">
        <select name="subject_id" onchange="this.form.submit()" class="w-full sm:w-auto px-4 py-2.5 rounded-xl border border-gray-250 dark:border-slate-800/80 bg-transparent text-sm focus:border-blue-500 outline-none text-gray-800 dark:text-slate-100 cursor-pointer">
          <option value="">-- Tất cả môn học --</option>
          {subjects.map(s => <option value={s.id} selected={filterSubject === s.id}>{s.name}</option>)}
        </select>

        <select name="type" onchange="this.form.submit()" class="w-full sm:w-auto px-4 py-2.5 rounded-xl border border-gray-250 dark:border-slate-800/80 bg-transparent text-sm focus:border-blue-500 outline-none text-gray-800 dark:text-slate-100 cursor-pointer">
          <option value="">-- Tất cả các dạng --</option>
          {Object.entries(qTypeNames).map(([val, label]) => <option value={val} selected={filterType === val}>{label}</option>)}
        </select>

        <select name="grade" onchange="this.form.submit()" class="w-full sm:w-auto px-4 py-2.5 rounded-xl border border-gray-250 dark:border-slate-800/80 bg-transparent text-sm focus:border-blue-500 outline-none text-gray-800 dark:text-slate-100 cursor-pointer">
          <option value="">-- Tất cả lớp học --</option>
          <option value="easy" selected={filterGrade === 'easy'}>Lớp 12 (Dễ)</option>
          <option value="medium" selected={filterGrade === 'medium'}>Lớp 12 (Trung bình)</option>
          <option value="hard" selected={filterGrade === 'hard'}>Lớp 12 (Khó)</option>
        </select>

        {categories.length > 0 && (
          <select name="category_id" onchange="this.form.submit()" class="w-full sm:w-auto px-4 py-2.5 rounded-xl border border-gray-250 dark:border-slate-800/80 bg-transparent text-sm focus:border-blue-500 outline-none text-gray-800 dark:text-slate-100 cursor-pointer">
            <option value="">-- Tất cả chuyên mục --</option>
            {categories.map(c => <option value={c.id} selected={filterCat === c.id}>{c.name}</option>)}
          </select>
        )}
      </form>

      <!-- Float action: Create Exam from Selected -->
      <div id="selection-actions" class="hidden flex items-center gap-3">
        <span class="text-sm font-bold text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/20 px-3 py-1.5 rounded-lg"><span id="selected-count">0</span> câu đang chọn</span>
        <button type="button" id="btn-create-exam" class="bg-indigo-600 hover:bg-indigo-700 text-white font-semibold px-4 py-2 rounded-xl text-sm shadow-md shadow-indigo-500/10 transition">
          Tạo đề thi
        </button>
      </div>
    </div>

    <!-- Table -->
    <div class="bg-white border border-gray-250 dark:bg-slate-900 dark:border-slate-800/80 rounded-2xl p-6 shadow-sm">
      {paginatedQuestions.length === 0 ? (
        <div class="text-center py-12 text-gray-500">Ngân hàng câu hỏi đang trống. Bấm nút phía trên để tạo câu hỏi trắc nghiệm đầu tiên!</div>
      ) : (
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-250 dark:divide-slate-800">
    <thead>
      <tr class="text-left text-xs font-bold text-gray-400 dark:text-slate-550 uppercase tracking-wider">
        <th class="pb-3 w-10">
          <input type="checkbox" id="selectAll" class="rounded text-blue-600 focus:ring-blue-500 h-4.5 w-4.5 cursor-pointer" />
        </th>
        <th class="pb-3">Câu hỏi</th>
        {isAdmin && <th class="pb-3">Giáo viên</th>}
        <th class="pb-3">Môn học</th>
        <th class="pb-3">Chuyên mục</th>
        <th class="pb-3">Lớp</th>
        <th class="pb-3">Dạng câu hỏi</th>
        <th class="pb-3">Độ khó</th>
        <th class="pb-3 text-right">Hành động</th>
      </tr>
    </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-slate-800/60 text-sm font-medium">
              {paginatedQuestions.map(q => (
                <tr class="text-gray-700 dark:text-slate-350">
                  <td class="py-4 pr-3">
                    <input type="checkbox" name="qIds" value={q.id} class="q-checkbox rounded text-blue-600 focus:ring-blue-500 h-4.5 w-4.5 cursor-pointer" />
                  </td>
                  <!-- Content Preview -->
                  <td class="py-4 pr-3 max-w-xs md:max-w-md align-top">
                    {q.type === 'read' || q.type === 'list' ? (
                      <details class="group">
                        <summary class="cursor-pointer list-none">
                          <p class="font-bold text-gray-900 dark:text-white truncate">{q.content.replace(/\$/g, '')}</p>
                          <span class="text-[10px] font-semibold text-indigo-500 dark:text-indigo-400">Xem chi tiết ▾</span>
                        </summary>
                        <div class="mt-2">
                          <ReadListPreview question={q} />
                        </div>
                      </details>
                    ) : (
                      <p class="font-bold text-gray-900 dark:text-white truncate">{q.content.replace(/\$/g, '')}</p>
                    )}
                    <span class="text-xs text-gray-450 dark:text-slate-500 mt-1 block">
                      {q.type === 'read' || q.type === 'list'
                        ? `${q.metadata?.questions?.length || 0} câu hỏi con`
                        : `${q.answers.length} phương án trả lời • Đáp án đúng: ${q.answers.filter(a => a.is_correct).map((_, i) => String.fromCharCode(65 + q.answers.findIndex(ans => ans.id === _.id))).join(', ')}`
                      }
                    </span>
                  </td>
                  {isAdmin && (
                    <td class="py-4 pr-3 text-xs text-gray-500 dark:text-slate-400 align-top">
                      {usersMap[q.created_by || '']?.fullname || usersMap[q.created_by || '']?.email || 'Hệ thống'}
                    </td>
                  )}
                  
                   <!-- Subject -->
                   <td class="py-4 pr-3">
                     <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-gray-100 text-gray-600 dark:bg-slate-850 dark:text-slate-300">
                       {getSubjectName(q.subject_id)}
                     </span>
                   </td>

                   <!-- Category -->
                   <td class="py-4 pr-3">
                     {(q.category_id || q.metadata?.category_id) && categoriesMap[q.category_id || q.metadata?.category_id] ? (
                       <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-indigo-50 text-indigo-600 dark:bg-indigo-950/30 dark:text-indigo-400 border border-indigo-100 dark:border-indigo-900/40">
                         {categoriesMap[(q.category_id || q.metadata?.category_id) as string].name}
                       </span>
                     ) : (
                       <span class="text-xs text-slate-400">—</span>
                     )}
                   </td>
                   
                   <!-- Grade -->
                   <td class="py-4 pr-3 text-xs text-gray-500 dark:text-slate-400">
                     {q.difficulty === 'easy' ? '12 (Dễ)' : q.difficulty === 'medium' ? '12 (TB)' : '12 (Khó)'}
                   </td>
                   
                   <!-- Type -->
                   <td class="py-4 pr-3 text-gray-500 dark:text-slate-400 text-xs">
                     {qTypeNames[q.type]}
                   </td>
                  
                  <!-- Difficulty -->
                  <td class="py-4 pr-3">
                    <span class={`inline-flex items-center px-2 py-0.5 rounded text-[10px] font-extrabold uppercase ${
                      q.difficulty === 'easy' 
                        ? 'bg-emerald-50 text-emerald-600 dark:bg-emerald-950/20 dark:text-emerald-400' 
                        : q.difficulty === 'medium' 
                          ? 'bg-amber-50 text-amber-600 dark:bg-amber-950/20 dark:text-amber-400' 
                          : 'bg-rose-50 text-rose-600 dark:bg-rose-950/20 dark:text-rose-400'
                    }`}>
                      {q.difficulty === 'easy' ? 'Dễ' : q.difficulty === 'medium' ? 'T.Bình' : 'Khó'}
                    </span>
                  </td>
                  
                  <!-- Actions -->
                  <td class="py-4 text-right space-x-3">
                    <a
                      href={`/admin/questions/edit/${q.id}`}
                      class="text-xs font-bold text-blue-600 dark:text-blue-400 hover:underline"
                    >
                      Sửa
                    </a>
                    
                    <form method="POST" class="inline" onsubmit="return confirm('Cậu có chắc chắn muốn xóa câu hỏi này? Việc này sẽ ảnh hưởng tới các đề thi chứa câu hỏi này.')">
                      <input type="hidden" name="action" value="delete" />
                      <input type="hidden" name="questionId" value={q.id} />
                      <button
                        type="submit"
                        class="text-xs font-bold text-rose-500 hover:underline bg-transparent border-none cursor-pointer"
                      >
                        Xóa
                      </button>
                    </form>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>

    <!-- Pagination -->
    {totalPages > 1 && (
      <div class="flex items-center justify-between bg-white border border-gray-250 dark:bg-slate-900 dark:border-slate-800/80 rounded-2xl p-4 shadow-sm">
        <span class="text-sm text-gray-500 dark:text-slate-400">
          Hiển thị trang <span class="font-bold text-gray-900 dark:text-white">{safePage}</span> / <span class="font-bold text-gray-900 dark:text-white">{totalPages}</span> 
          <span class="hidden sm:inline">(Tổng: {totalItems} câu)</span>
        </span>
        
          <div class="flex gap-2">
            {safePage > 1 ? (
              <a href={`?page=${safePage - 1}&subject_id=${filterSubject}&type=${filterType}&grade=${filterGrade}`} class="px-4 py-2 border border-gray-250 dark:border-slate-700 rounded-lg text-sm font-semibold hover:bg-gray-50 dark:hover:bg-slate-800 text-gray-700 dark:text-slate-200 transition">Trang trước</a>
            ) : (
              <span class="px-4 py-2 border border-gray-200 dark:border-slate-800 rounded-lg text-sm font-semibold text-gray-400 dark:text-slate-600 cursor-not-allowed">Trang trước</span>
            )}
            
            {safePage < totalPages ? (
              <a href={`?page=${safePage + 1}&subject_id=${filterSubject}&type=${filterType}&grade=${filterGrade}`} class="px-4 py-2 border border-gray-250 dark:border-slate-700 rounded-lg text-sm font-semibold hover:bg-gray-50 dark:hover:bg-slate-800 text-gray-700 dark:text-slate-200 transition">Trang sau</a>
            ) : (
              <span class="px-4 py-2 border border-gray-200 dark:border-slate-800 rounded-lg text-sm font-semibold text-gray-400 dark:text-slate-600 cursor-not-allowed">Trang sau</span>
            )}
          </div>
      </div>
    )}

  </div>
</Layout>

<script>
  const selectAll = document.getElementById('selectAll') as HTMLInputElement;
  const qCheckboxes = document.querySelectorAll('.q-checkbox') as NodeListOf<HTMLInputElement>;
  const selectionActions = document.getElementById('selection-actions');
  const selectedCount = document.getElementById('selected-count');
  const btnCreateExam = document.getElementById('btn-create-exam');

  function updateSelection() {
    const checked = document.querySelectorAll('.q-checkbox:checked');
    const count = checked.length;
    if (selectedCount) selectedCount.textContent = count.toString();
    
    if (count > 0) {
      selectionActions?.classList.remove('hidden');
    } else {
      selectionActions?.classList.add('hidden');
    }

    if (selectAll) {
      selectAll.checked = count > 0 && count === qCheckboxes.length;
    }
  }

  if (selectAll) {
    selectAll.addEventListener('change', () => {
      qCheckboxes.forEach(cb => cb.checked = selectAll.checked);
      updateSelection();
    });
  }

  qCheckboxes.forEach(cb => {
    cb.addEventListener('change', updateSelection);
  });

  if (btnCreateExam) {
    btnCreateExam.addEventListener('click', () => {
      const checked = document.querySelectorAll('.q-checkbox:checked');
      const ids = Array.from(checked).map((cb: any) => cb.value);
      if (ids.length > 0) {
        window.location.href = `${import.meta.env.BASE_URL}/admin/exams/new?q=${ids.join(',')}`;
      }
    });
  }
</script>
