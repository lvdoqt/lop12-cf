---
import Layout from '../../../../../../layouts/Layout.astro';
import { db } from '../../../../../../services/db';

export const prerender = false;

const user = Astro.locals.user;
if (!user || (user.role !== 'admin' && user.role !== 'teacher')) {
  return Astro.redirect('/dashboard');
}

const { id, lid } = Astro.params;
if (!id || !lid) return Astro.redirect('/admin/courses');

const course = await db.getCourseById(id);
const lesson = await db.getCourseLessonById(lid);
if (!course || !lesson) return Astro.redirect(`/admin/courses/${id}`);

let error = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const title = (form.get('title') as string || '').trim();
  const content = (form.get('content') as string || '').trim();
  const video_url = (form.get('video_url') as string || '').trim() || null;
  const order_index = parseInt(form.get('order_index') as string) || lesson.order_index;
  const duration = parseInt(form.get('duration') as string) || null;
  const is_published = form.getAll('is_published').includes('1');

  if (!title) {
    error = 'Tiêu đề bài giảng không được để trống.';
  } else {
    try {
      await db.updateCourseLesson(lid, { title, content: content || null, video_url, order_index, duration, is_published });
      return Astro.redirect(`/admin/courses/${id}`);
    } catch (e: any) {
      error = e.message || 'Có lỗi xảy ra.';
    }
  }
}
---

<Layout title={`Sửa: ${lesson.title}`}>
  <div class="max-w-3xl mx-auto space-y-6">
    <div>
      <a href={`/admin/courses/${id}`} class="inline-flex items-center text-xs font-bold text-gray-400 hover:text-gray-600 dark:hover:text-slate-350 transition-colors uppercase tracking-wider mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
        {course.title}
      </a>
      <h1 class="text-2xl font-extrabold text-gray-900 dark:text-white">Sửa bài giảng</h1>
    </div>

    {error && (
      <div class="p-4 rounded-xl bg-rose-50 dark:bg-rose-950/20 border border-rose-200 dark:border-rose-900/30 text-rose-700 dark:text-rose-400 text-sm font-medium">{error}</div>
    )}

    <form method="POST" class="bg-white dark:bg-slate-900 border border-gray-200 dark:border-slate-800 rounded-2xl p-6 space-y-5 shadow-sm">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="md:col-span-2">
          <label class="block text-sm font-bold text-gray-700 dark:text-slate-200 mb-1.5">Tiêu đề bài giảng <span class="text-rose-500">*</span></label>
          <input type="text" name="title" required value={lesson.title} class="w-full px-4 py-2.5 rounded-xl border border-gray-250 dark:border-slate-700 bg-white dark:bg-slate-950 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm" />
        </div>
        <div>
          <label class="block text-sm font-bold text-gray-700 dark:text-slate-200 mb-1.5">Thứ tự</label>
          <input type="number" name="order_index" value={lesson.order_index} min="1" class="w-full px-4 py-2.5 rounded-xl border border-gray-250 dark:border-slate-700 bg-white dark:bg-slate-950 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm" />
        </div>
      </div>

      <div>
        <label class="block text-sm font-bold text-gray-700 dark:text-slate-200 mb-1.5">Link video YouTube</label>
        <input type="url" name="video_url" value={lesson.video_url || ''} placeholder="https://www.youtube.com/watch?v=..." class="w-full px-4 py-2.5 rounded-xl border border-gray-250 dark:border-slate-700 bg-white dark:bg-slate-950 text-gray-900 dark:text-white placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm" />
      </div>

      <div>
        <label class="block text-sm font-bold text-gray-700 dark:text-slate-200 mb-1.5">Thời lượng (phút)</label>
        <input type="number" name="duration" value={lesson.duration || ''} min="1" placeholder="VD: 15" class="w-full px-4 py-2.5 rounded-xl border border-gray-250 dark:border-slate-700 bg-white dark:bg-slate-950 text-gray-900 dark:text-white placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm" />
      </div>

      <div>
        <label class="block text-sm font-bold text-gray-700 dark:text-slate-200 mb-1.5">Nội dung bài giảng (Markdown)</label>
        <textarea
          name="content"
          rows="14"
          class="w-full px-4 py-2.5 rounded-xl border border-gray-250 dark:border-slate-700 bg-white dark:bg-slate-950 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm font-mono resize-y"
        >{lesson.content || ''}</textarea>
      </div>

      <div class="flex items-center gap-3 p-4 rounded-xl bg-gray-50 dark:bg-slate-800/50 border border-gray-200 dark:border-slate-700">
        <input type="hidden" name="is_published" value="0" />
        <input type="checkbox" name="is_published" id="is_published" value="1" checked={lesson.is_published} class="w-4 h-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
        <label for="is_published" class="text-sm font-bold text-gray-700 dark:text-slate-200 cursor-pointer">Hiển thị bài giảng này</label>
      </div>

      <div class="flex gap-3 pt-2">
        <button type="submit" class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2.5 rounded-xl text-sm transition shadow shadow-blue-500/20">
          Lưu thay đổi
        </button>
        <a href={`/admin/courses/${id}`} class="px-5 py-2.5 rounded-xl border border-gray-250 dark:border-slate-700 text-gray-600 dark:text-slate-300 hover:bg-gray-50 dark:hover:bg-slate-800 text-sm font-semibold transition">
          Hủy
        </a>
      </div>
    </form>
  </div>
</Layout>
