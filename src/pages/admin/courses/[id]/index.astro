---
import Layout from '../../../../layouts/Layout.astro';
import { db } from '../../../../services/db';

export const prerender = false;

const user = Astro.locals.user;
if (!user || (user.role !== 'admin' && user.role !== 'teacher')) {
  return Astro.redirect('/dashboard');
}

const { id } = Astro.params;
if (!id) return Astro.redirect('/admin/courses');

const course = await db.getCourseById(id);
if (!course) return Astro.redirect('/admin/courses');

const lessons = await db.getCourseLessons(id);

// Handle DELETE lesson action
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action') as string;
  const lessonId = form.get('lesson_id') as string;
  if (action === 'delete_lesson' && lessonId) {
    await db.deleteCourseLesson(lessonId);
    return Astro.redirect(`/admin/courses/${id}`);
  }
  if (action === 'toggle_publish') {
    await db.updateCourse(id, { is_published: !course.is_published });
    return Astro.redirect(`/admin/courses/${id}`);
  }
  if (action === 'delete_course') {
    await db.deleteCourse(id);
    return Astro.redirect('/admin/courses');
  }
}
---

<Layout title={`Quản lý: ${course.title}`}>
  <div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-start justify-between gap-4">
      <div>
        <a href="/admin/courses" class="inline-flex items-center text-xs font-bold text-gray-400 hover:text-gray-600 dark:hover:text-slate-350 transition-colors uppercase tracking-wider mb-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
          Quản lý khóa học
        </a>
        <div class="flex items-center gap-3 flex-wrap">
          <h1 class="text-2xl font-extrabold text-gray-900 dark:text-white">{course.title}</h1>
          <span class={`px-2.5 py-1 rounded-full text-xs font-bold ${course.is_published ? 'bg-emerald-50 text-emerald-700 dark:bg-emerald-900/20 dark:text-emerald-400' : 'bg-yellow-50 text-yellow-700 dark:bg-yellow-900/20 dark:text-yellow-400'}`}>
            {course.is_published ? '✓ Đã xuất bản' : '○ Bản nháp'}
          </span>
        </div>
        <p class="text-sm text-gray-500 dark:text-slate-400 mt-1">{course.subject?.name} · {lessons.length} bài giảng</p>
      </div>

      <div class="flex flex-wrap gap-2 shrink-0">
        <a href={`/admin/courses/${id}/edit`} class="inline-flex items-center gap-1.5 bg-white dark:bg-slate-900 border border-gray-250 dark:border-slate-700 text-gray-700 dark:text-slate-200 hover:bg-gray-50 dark:hover:bg-slate-800 px-4 py-2 rounded-xl text-sm font-semibold transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
          Sửa thông tin
        </a>
        <form method="POST" class="inline">
          <input type="hidden" name="_action" value="toggle_publish" />
          <button type="submit" class={`inline-flex items-center gap-1.5 px-4 py-2 rounded-xl text-sm font-semibold transition ${course.is_published ? 'bg-yellow-50 dark:bg-yellow-900/20 text-yellow-700 dark:text-yellow-400 border border-yellow-200 dark:border-yellow-800/40 hover:bg-yellow-100' : 'bg-emerald-50 dark:bg-emerald-900/20 text-emerald-700 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-800/40 hover:bg-emerald-100'}`}>
            {course.is_published ? 'Ẩn khóa học' : 'Xuất bản'}
          </button>
        </form>
        <a href={`/admin/courses/${id}/lessons/new`} class="inline-flex items-center gap-1.5 bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-xl text-sm font-semibold transition shadow shadow-blue-500/20">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
          Thêm bài giảng
        </a>
      </div>
    </div>

    <!-- Preview link -->
    <div class="p-3 bg-blue-50 dark:bg-blue-900/10 border border-blue-100 dark:border-blue-900/30 rounded-xl flex items-center gap-3 text-sm">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-blue-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
      <span class="text-blue-700 dark:text-blue-300">Học sinh xem tại: <a href={`/khoa-hoc/${course.slug}`} target="_blank" class="font-bold underline hover:no-underline">/khoa-hoc/{course.slug}</a></span>
    </div>

    <!-- Lessons List -->
    <div class="bg-white dark:bg-slate-900 border border-gray-200 dark:border-slate-800 rounded-2xl shadow-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 dark:border-slate-800 flex items-center justify-between">
        <h2 class="font-bold text-gray-900 dark:text-white">Danh sách bài giảng</h2>
        <span class="text-xs text-gray-400">{lessons.length} bài</span>
      </div>

      {lessons.length === 0 ? (
        <div class="text-center py-16">
          <p class="text-gray-400 dark:text-slate-500 text-sm">Chưa có bài giảng nào.</p>
          <a href={`/admin/courses/${id}/lessons/new`} class="inline-flex items-center gap-1.5 mt-3 text-blue-600 dark:text-blue-400 text-sm font-bold hover:underline">
            Thêm bài giảng đầu tiên →
          </a>
        </div>
      ) : (
        <div class="divide-y divide-gray-100 dark:divide-slate-800">
          {lessons.map((lesson, idx) => (
            <div class="flex items-center gap-4 px-6 py-4 hover:bg-gray-50 dark:hover:bg-slate-800/50 transition group">
              <!-- Order -->
              <span class="w-7 h-7 rounded-lg bg-gray-100 dark:bg-slate-800 text-gray-500 dark:text-slate-400 text-xs font-bold flex items-center justify-center shrink-0">
                {lesson.order_index}
              </span>

              <!-- Info -->
              <div class="flex-1 min-w-0">
                <p class="font-semibold text-gray-900 dark:text-white text-sm truncate">{lesson.title}</p>
                <div class="flex items-center gap-3 mt-0.5 text-xs text-gray-400 dark:text-slate-500">
                  {lesson.duration && <span>{lesson.duration} phút</span>}
                  {lesson.video_url && <span class="text-blue-500">▶ Video</span>}
                  <span class={lesson.is_published ? 'text-emerald-500' : 'text-gray-400'}>
                    {lesson.is_published ? 'Hiển thị' : 'Ẩn'}
                  </span>
                </div>
              </div>

              <!-- Actions -->
              <div class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition shrink-0">
                <a href={`/admin/courses/${id}/lessons/${lesson.id}/edit`} class="px-3 py-1.5 text-xs font-bold text-blue-600 dark:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg transition">
                  Sửa
                </a>
                <form method="POST" onsubmit="return confirm('Xóa bài giảng này?')">
                  <input type="hidden" name="_action" value="delete_lesson" />
                  <input type="hidden" name="lesson_id" value={lesson.id} />
                  <button type="submit" class="px-3 py-1.5 text-xs font-bold text-rose-600 dark:text-rose-400 hover:bg-rose-50 dark:hover:bg-rose-900/20 rounded-lg transition">
                    Xóa
                  </button>
                </form>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- Danger zone -->
    <details class="group">
      <summary class="cursor-pointer text-sm font-semibold text-gray-400 hover:text-rose-500 dark:hover:text-rose-400 transition flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 group-open:rotate-90 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        Vùng nguy hiểm
      </summary>
      <div class="mt-3 p-4 rounded-xl border border-rose-200 dark:border-rose-900/40 bg-rose-50/50 dark:bg-rose-950/10 flex items-center justify-between">
        <div>
          <p class="text-sm font-bold text-rose-700 dark:text-rose-400">Xóa khóa học</p>
          <p class="text-xs text-rose-500 dark:text-rose-500/70 mt-0.5">Thao tác này không thể hoàn tác. Tất cả bài giảng sẽ bị xóa.</p>
        </div>
        <form method="POST" onsubmit="return confirm('Bạn chắc chắn muốn xóa toàn bộ khóa học này?')">
          <input type="hidden" name="_action" value="delete_course" />
          <button type="submit" class="px-4 py-2 text-sm font-bold text-white bg-rose-600 hover:bg-rose-700 rounded-xl transition">
            Xóa khóa học
          </button>
        </form>
      </div>
    </details>
  </div>
</Layout>
