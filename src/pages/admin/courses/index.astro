---
import Layout from '../../../layouts/Layout.astro';
import { db } from '../../../services/db';

export const prerender = false;

const user = Astro.locals.user;
if (!user || (user.role !== 'admin' && user.role !== 'teacher')) {
  return Astro.redirect('/dashboard');
}

const courses = await db.getCourses({ createdBy: user.role === 'admin' ? undefined : user.id });
---

<Layout title="Quản lý Khóa học">
  <div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
      <div>
        <a href="/admin" class="inline-flex items-center text-xs font-bold text-gray-400 hover:text-gray-600 dark:hover:text-slate-350 transition-colors uppercase tracking-wider mb-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          Quản trị Admin
        </a>
        <h1 class="text-2xl md:text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight">Quản lý Khóa học</h1>
        <p class="text-sm text-gray-500 dark:text-slate-400 mt-1">Tạo và quản lý khóa học, bài giảng cho học sinh.</p>
      </div>
      <a href="/admin/courses/new" class="inline-flex items-center bg-blue-600 hover:bg-blue-700 text-white font-semibold px-5 py-2.5 rounded-xl shadow shadow-blue-500/20 transition text-sm shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
        Tạo khóa học mới
      </a>
    </div>

    <!-- Course List -->
    {courses.length === 0 ? (
      <div class="text-center py-20 bg-white dark:bg-slate-900 border border-gray-200 dark:border-slate-800 rounded-2xl">
        <div class="w-16 h-16 bg-blue-50 dark:bg-blue-900/20 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
        </div>
        <p class="text-gray-500 dark:text-slate-400 font-medium mb-4">Chưa có khóa học nào.</p>
        <a href="/admin/courses/new" class="inline-flex items-center bg-blue-600 hover:bg-blue-700 text-white font-semibold px-5 py-2.5 rounded-xl text-sm transition">
          Tạo khóa học đầu tiên
        </a>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {courses.map(course => (
          <div class="bg-white dark:bg-slate-900 border border-gray-200 dark:border-slate-800 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow flex flex-col">
            <!-- Status badge -->
            <div class="flex items-center justify-between mb-4">
              <span class={`inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold ${course.is_published ? 'bg-emerald-50 text-emerald-700 dark:bg-emerald-900/20 dark:text-emerald-400' : 'bg-gray-100 text-gray-500 dark:bg-slate-800 dark:text-slate-400'}`}>
                {course.is_published ? '✓ Đã xuất bản' : '○ Bản nháp'}
              </span>
              <span class="text-xs text-gray-400 dark:text-slate-500">{course.subject?.name || 'Chưa phân loại'}</span>
            </div>

            <h3 class="font-bold text-gray-900 dark:text-white text-base leading-snug mb-2 line-clamp-2">{course.title}</h3>
            <p class="text-sm text-gray-500 dark:text-slate-400 line-clamp-2 mb-3 flex-1">{course.description || 'Chưa có mô tả.'}</p>

            <!-- Teacher -->
            {course.teacher && (
              <div class="flex items-center gap-2 mb-3">
                <img
                  src={course.teacher.avatar_url || `https://api.dicebear.com/7.x/adventurer/svg?seed=${course.teacher.fullname || 'teacher'}`}
                  alt={course.teacher.fullname || ''}
                  class="w-5 h-5 rounded-full object-cover bg-gray-200 dark:bg-slate-700"
                />
                <span class="text-xs text-gray-600 dark:text-slate-300 truncate">{course.teacher.fullname || 'Giáo viên'}</span>
              </div>
            )}

            <div class="flex items-center gap-4 text-xs text-gray-400 dark:text-slate-500 mb-4 pt-3 border-t border-gray-100 dark:border-slate-800">
              <span class="flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
                {course.lessonCount ?? 0} bài giảng
              </span>
              <span class="flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
                {course.enrollmentCount ?? 0} học sinh
              </span>
            </div>

            <div class="flex gap-2">
              <a href={`/admin/courses/${course.id}`} class="flex-1 text-center bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-400 hover:bg-blue-100 dark:hover:bg-blue-900/40 font-semibold px-3 py-2 rounded-xl text-sm transition">
                Quản lý bài giảng
              </a>
              <a href={`/admin/courses/${course.id}/edit`} class="px-3 py-2 text-gray-500 dark:text-slate-400 hover:text-gray-700 dark:hover:text-slate-200 hover:bg-gray-100 dark:hover:bg-slate-800 rounded-xl transition text-sm" title="Sửa khóa học">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</Layout>
