---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Liên hệ" description="Liên hệ với đội ngũ kỹ thuật và nội dung của Lớp 12 LMS. Gửi ý kiến phản hồi hoặc yêu cầu hỗ trợ.">
  <div class="space-y-12 max-w-5xl mx-auto">
    <!-- Header -->
    <div class="text-center space-y-4">
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight font-outfit text-gray-900 dark:text-white">
        Kết nối với chúng tôi
      </h1>
      <p class="text-sm md:text-base text-gray-550 dark:text-slate-400 font-semibold max-w-2xl mx-auto">
        Cậu có thắc mắc, đề xuất nội dung bài giảng hay gặp sự cố kỹ thuật? Hãy để lại thông tin, chúng tôi sẽ hỗ trợ nhanh nhất có thể.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Contact Info Cards -->
      <div class="lg:col-span-1 space-y-6">
        {[
          {
            title: 'Hỗ trợ học tập',
            detail: 'support@lop12.vn',
            sub: 'Giải đáp thắc mắc tài liệu, bài tập',
            icon: '✉️'
          },
          {
            title: 'Hotline tuyển sinh',
            detail: '1900 1234 (8:00 - 21:00)',
            sub: 'Tư vấn lộ trình ôn thi THPT Quốc gia',
            icon: '📞'
          },
          {
            title: 'Địa chỉ văn phòng',
            detail: 'Khu Công nghệ cao, Quận 9, TP. Hồ Chí Minh',
            sub: 'Trung tâm Nghiên cứu Giáo dục Số',
            icon: '📍'
          }
        ].map(item => (
          <div class="bg-white dark:bg-slate-900 border border-gray-200/60 dark:border-slate-800/80 rounded-2xl p-6 space-y-2 shadow-sm">
            <span class="text-2xl">{item.icon}</span>
            <h4 class="text-base font-bold text-gray-900 dark:text-white font-outfit">{item.title}</h4>
            <p class="text-sm font-extrabold text-blue-600 dark:text-blue-400">{item.detail}</p>
            <p class="text-xs text-gray-400 dark:text-slate-500 font-medium">{item.sub}</p>
          </div>
        ))}
      </div>

      <!-- Contact Form Container -->
      <div class="lg:col-span-2 bg-white dark:bg-slate-900 border border-gray-200/60 dark:border-slate-800/80 rounded-3xl p-6 md:p-10 shadow-sm relative overflow-hidden">
        <div id="success-alert" class="hidden absolute inset-0 bg-white dark:bg-slate-900 z-10 flex flex-col items-center justify-center text-center p-8 space-y-4">
          <div class="w-16 h-16 rounded-full bg-emerald-100 dark:bg-emerald-950/40 text-emerald-600 dark:text-emerald-400 flex items-center justify-center text-3xl">
            ✓
          </div>
          <h3 class="text-2xl font-bold font-outfit text-gray-900 dark:text-white">Gửi liên hệ thành công!</h3>
          <p class="text-sm text-gray-500 dark:text-slate-400 max-w-sm font-medium">
            Cảm ơn cậu đã liên hệ với Lớp 12 LMS. Đội ngũ hỗ trợ sẽ phản hồi lại qua Email trong vòng 24 giờ làm việc.
          </p>
          <button id="reset-form-btn" class="px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white rounded-xl text-sm font-semibold shadow-md shadow-blue-500/10 transition-colors">
            Gửi phản hồi mới
          </button>
        </div>

        <form id="contact-form" class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label for="name" class="text-xs font-bold text-gray-500 dark:text-slate-400 uppercase tracking-wider">Họ và tên</label>
              <input type="text" id="name" required class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-950 border border-gray-250 dark:border-slate-800 rounded-xl text-sm focus:outline-none focus:border-blue-500 transition-colors" placeholder="Nguyễn Văn A" />
            </div>
            <div class="space-y-2">
              <label for="email" class="text-xs font-bold text-gray-500 dark:text-slate-400 uppercase tracking-wider">Email liên hệ</label>
              <input type="email" id="email" required class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-950 border border-gray-250 dark:border-slate-800 rounded-xl text-sm focus:outline-none focus:border-blue-500 transition-colors" placeholder="example@gmail.com" />
            </div>
          </div>

          <div class="space-y-2">
            <label for="role" class="text-xs font-bold text-gray-500 dark:text-slate-400 uppercase tracking-wider">Vai trò của bạn</label>
            <select id="role" class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-950 border border-gray-250 dark:border-slate-800 rounded-xl text-sm focus:outline-none focus:border-blue-500 transition-colors">
              <option value="student">Học sinh lớp 12</option>
              <option value="teacher">Giáo viên / Phụ huynh</option>
              <option value="other">Ý kiến đóng góp khác</option>
            </select>
          </div>

          <div class="space-y-2">
            <label for="message" class="text-xs font-bold text-gray-500 dark:text-slate-400 uppercase tracking-wider">Nội dung tin nhắn</label>
            <textarea id="message" required rows="5" class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-950 border border-gray-250 dark:border-slate-800 rounded-xl text-sm focus:outline-none focus:border-blue-500 transition-colors" placeholder="Cậu muốn chia sẻ điều gì với chúng tôi..."></textarea>
          </div>

          <button type="submit" class="w-full md:w-auto px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-xl text-sm font-semibold shadow-lg shadow-blue-500/10 hover:shadow-blue-500/20 transition-all flex items-center justify-center gap-2">
            Gửi tin nhắn phản hồi
            <span>🚀</span>
          </button>
        </form>
      </div>
    </div>
  </div>

  <script is:inline>
    const form = document.getElementById('contact-form');
    const successAlert = document.getElementById('success-alert');
    const resetBtn = document.getElementById('reset-form-btn');

    if (form && successAlert) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        successAlert.classList.remove('hidden');
      });
    }

    if (resetBtn && form && successAlert) {
      resetBtn.addEventListener('click', () => {
        form.reset();
        successAlert.classList.add('hidden');
      });
    }
  </script>
</Layout>
