---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sơ đồ trang web (Sitemap)" description="Sơ đồ cấu trúc đường dẫn hệ thống giúp học sinh và giáo viên dễ dàng truy cập nhanh tất cả các tính năng của Lớp 12 LMS.">
  <div class="space-y-12 max-w-5xl mx-auto">
    <!-- Header -->
    <div class="text-center space-y-4">
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight font-outfit text-gray-900 dark:text-white">
        Sơ đồ trang web - Sitemap
      </h1>
      <p class="text-sm md:text-base text-gray-550 dark:text-slate-400 font-semibold max-w-2xl mx-auto">
        Tổng hợp tất cả các liên kết nhanh để bạn dễ dàng bao quát và truy cập mọi ngóc ngách của cổng học tập Lớp 12 LMS.
      </p>
      <!-- XML Feed Badges -->
      <div class="flex flex-wrap items-center justify-center gap-3 pt-2">
        <a
          href="/sitemap.xml"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-bold bg-blue-50 dark:bg-blue-950/30 text-blue-700 dark:text-blue-300 border border-blue-200/70 dark:border-blue-800/50 hover:bg-blue-100 dark:hover:bg-blue-900/40 transition-colors"
        >
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
          Sitemap XML (Dành cho Search Engine)
        </a>
        <a
          href="/rss.xml"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-bold bg-orange-50 dark:bg-orange-950/30 text-orange-700 dark:text-orange-300 border border-orange-200/70 dark:border-orange-800/50 hover:bg-orange-100 dark:hover:bg-orange-900/40 transition-colors"
        >
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
          </svg>
          RSS Feed (Bản tin Blog)
        </a>
      </div>
    </div>

    <!-- Sitemap Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      
      <!-- Box 1: Core Portal -->
      <div class="bg-white dark:bg-slate-900 border border-gray-200/60 dark:border-slate-800/80 rounded-3xl p-6 md:p-8 space-y-4 shadow-sm hover:border-blue-500/20 transition-colors">
        <div class="flex items-center gap-2.5">
          <span class="text-xl">🏠</span>
          <h3 class="text-lg font-bold text-gray-900 dark:text-white font-outfit">Hệ thống & Tài khoản</h3>
        </div>
        <ul class="space-y-2 text-sm font-semibold text-gray-600 dark:text-slate-350">
          <li><a href="/" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors block py-0.5">• Trang chủ chính (Landing Page)</a></li>
          <li><a href="/login" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors block py-0.5">• Đăng nhập tài khoản</a></li>
          <li><a href="/register" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors block py-0.5">• Đăng ký tài khoản</a></li>
          <li><a href="/forgot-password" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors block py-0.5">• Quên mật khẩu</a></li>
          <li><a href="/dashboard" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors block py-0.5">• Bảng điều khiển cá nhân (Dashboard)</a></li>
          <li><a href="/profile" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors block py-0.5">• Trang cá nhân & Tiến độ học</a></li>
        </ul>
      </div>

      <!-- Box 2: Learning Sections -->
      <div class="bg-white dark:bg-slate-900 border border-gray-200/60 dark:border-slate-800/80 rounded-3xl p-6 md:p-8 space-y-4 shadow-sm hover:border-indigo-500/20 transition-colors">
        <div class="flex items-center gap-2.5">
          <span class="text-xl">📚</span>
          <h3 class="text-lg font-bold text-gray-900 dark:text-white font-outfit">Học tập & Luyện thi</h3>
        </div>
        <ul class="space-y-2 text-sm font-semibold text-gray-600 dark:text-slate-350">
          <li><a href="/ly-thuyet" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors block py-0.5">• Danh sách Lý thuyết lớp 12</a></li>
          <li><span class="text-gray-400 dark:text-slate-600 block py-0.5">• Thi thử trắc nghiệm online (15m, 45m, Học kỳ)</span></li>
          <li><span class="text-gray-400 dark:text-slate-600 block py-0.5">• Kết quả & Giải thích chi tiết đề thi</span></li>
        </ul>
      </div>

      <!-- Box 3: Informational Footer pages -->
      <div class="bg-white dark:bg-slate-900 border border-gray-200/60 dark:border-slate-800/80 rounded-3xl p-6 md:p-8 space-y-4 shadow-sm hover:border-purple-500/20 transition-colors">
        <div class="flex items-center gap-2.5">
          <span class="text-xl">ℹ️</span>
          <h3 class="text-lg font-bold text-gray-900 dark:text-white font-outfit">Thông tin bổ trợ</h3>
        </div>
        <ul class="space-y-2 text-sm font-semibold text-gray-600 dark:text-slate-350">
          <li><a href="/about" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors block py-0.5">• Giới thiệu về LMS</a></li>
          <li><a href="/guide" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors block py-0.5">• Hướng dẫn học tập</a></li>
          <li><a href="/contact" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors block py-0.5">• Liên hệ hỗ trợ & Góp ý</a></li>
          <li><a href="/privacy" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors block py-0.5">• Chính sách bảo mật dữ liệu</a></li>
          <li><a href="/sitemap" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors block py-0.5">• Sơ đồ trang web (Trang hiện tại)</a></li>
        </ul>
      </div>

      <!-- Box 4: Admin Panel (For Admin/Teachers) -->
      <div class="bg-white dark:bg-slate-900 border border-gray-200/60 dark:border-slate-800/80 rounded-3xl p-6 md:p-8 space-y-4 shadow-sm hover:border-rose-500/20 transition-colors md:col-span-2 lg:col-span-3">
        <div class="flex items-center gap-2.5">
          <span class="text-xl">⚙️</span>
          <h3 class="text-lg font-bold text-gray-900 dark:text-white font-outfit">Trang quản trị (Dành cho Quản trị viên & Giáo viên)</h3>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 pt-2">
          <div>
            <h4 class="text-xs font-bold text-gray-450 dark:text-slate-500 uppercase tracking-widest mb-2">Tổng quan</h4>
            <ul class="space-y-1.5 text-xs font-semibold text-gray-500 dark:text-slate-400">
              <li><a href="/admin" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors block">• Dashboard quản trị</a></li>
              <li><a href="/admin/users" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors block">• Phân quyền tài khoản</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-xs font-bold text-gray-450 dark:text-slate-500 uppercase tracking-widest mb-2">Lý thuyết</h4>
            <ul class="space-y-1.5 text-xs font-semibold text-gray-500 dark:text-slate-400">
              <li><a href="/admin/lessons" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors block">• Quản lý bài học</a></li>
              <li><a href="/admin/lessons/new" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors block">• Thêm bài học mới</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-xs font-bold text-gray-450 dark:text-slate-500 uppercase tracking-widest mb-2">Câu hỏi trắc nghiệm</h4>
            <ul class="space-y-1.5 text-xs font-semibold text-gray-500 dark:text-slate-400">
              <li><a href="/admin/questions" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors block">• Kho câu hỏi trắc nghiệm</a></li>
              <li><a href="/admin/questions/new" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors block">• Thêm câu hỏi trắc nghiệm</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-xs font-bold text-gray-450 dark:text-slate-500 uppercase tracking-widest mb-2">Đề thi</h4>
            <ul class="space-y-1.5 text-xs font-semibold text-gray-500 dark:text-slate-400">
              <li><a href="/admin/exams" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors block">• Quản lý đề thi online</a></li>
              <li><a href="/admin/exams/new" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors block">• Thiết lập đề thi mới</a></li>
            </ul>
          </div>
        </div>
      </div>

    </div>
  </div>
</Layout>
