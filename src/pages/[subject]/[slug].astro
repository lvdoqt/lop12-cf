---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import QuestionCard from '../../components/QuestionCard.astro';
import { db } from '../../services/db';

export const prerender = false;

const { subject: subjectParam, slug } = Astro.params;

// Find matching lesson entry dynamically (SSR)
const allLessonEntries = await getCollection('lessons');
const entry = allLessonEntries.find(e => {
  const parts = e.id.split('/');
  const entrySlug = parts.pop() || e.id;
  const entrySubjectDir = parts[0] || '';
  return entrySubjectDir === subjectParam && entrySlug === slug;
});

if (!entry) {
  return Astro.redirect('/ly-thuyet');
}

const lessonData = entry.data.lessons && entry.data.lessons.length > 0 ? entry.data.lessons[0] : null;
if (!lessonData) {
  return Astro.redirect('/ly-thuyet');
}

const subjects = await db.getSubjects();
const subject = subjects.find(s => s.slug === subjectParam);

const allLessons = await getCollection('lessons');
const subjectLessons = allLessons
  .filter(l => l.id.startsWith(subjectParam + '/'))
  .sort((a, b) => {
    const orderA = a.data.lessons?.[0]?.lesson_id || 0;
    const orderB = b.data.lessons?.[0]?.lesson_id || 0;
    return orderA - orderB;
  });

const currentIndex = subjectLessons.findIndex(l => l.id === entry.id);
const prevLesson = currentIndex > 0 ? subjectLessons[currentIndex - 1] : null;
const nextLesson = currentIndex < subjectLessons.length - 1 ? subjectLessons[currentIndex + 1] : null;

const getSlug = (id: string) => id.split('/').pop() || id;

let quizQuestions: any[] = [];

if (lessonData.content?.exercises && lessonData.content.exercises.length > 0) {
  const supportedTypes = ['mcq', 'msq', 'sa', 'essay', 'tl', 'read', 'list'];
  quizQuestions = lessonData.content.exercises
    .filter((ex: any) => supportedTypes.includes(ex.type))
    .flatMap((ex: any, qIdx: number) => {
      if (ex.type === 'read' || ex.type === 'list') {
        const subQuestions = ex.metadata?.questions || [];
        return subQuestions.map((sq: any, sqIdx: number) => {
          const optionLetters = ['A', 'B', 'C', 'D', 'E', 'F'];
          const options: string[] = [];
          for (const letter of optionLetters) {
            if (sq['option_' + letter.toLowerCase()]) {
              options.push(sq['option_' + letter.toLowerCase()]);
            }
          }
          return {
            id: `ex_${qIdx}_${sqIdx}`,
            type: 'single_choice',
            difficulty: 'medium',
            content: (ex.content || '') + '\n\n' + sq.question,
            explanation: sq.explanation || '',
            answers: options.map((opt: string, i: number) => ({
              id: `opt_${qIdx}_${sqIdx}_${i}`,
              content: opt,
              is_correct: optionLetters[i] === (sq.correct_option || '').toUpperCase()
            })),
            answer: sq.correct_option
          };
        });
      }
      
      let options = ex.options ? [...ex.options] : [];
      let correctStrings: string[] = [];
      if (options.length > 0) {
        if (Array.isArray(ex.correct)) {
          correctStrings = ex.correct.map((i: number) => options[i]);
        } else if (ex.correct !== undefined) {
          correctStrings = [options[ex.correct]];
        }
      }
      
      let type = ex.type;
      if (type === 'mcq') type = 'single_choice';
      else if (type === 'msq') type = 'msq';
      else if (type === 'sa') type = 'sa';
      else if (type === 'essay') type = 'tl';
      
      return {
        id: `ex_${qIdx}`,
        type,
        difficulty: 'medium',
        content: ex.question,
        explanation: ex.explanation,
        answers: options.map((opt: string, i: number) => ({
          id: `opt_${qIdx}_${i}`,
          content: opt,
          is_correct: correctStrings.includes(opt)
        })),
        answer: ex.correct
      };
    });
}

// Helper: YouTube embed URL parser
function getYoutubeEmbedUrl(url: string | null | undefined) {
  if (!url) return null;
  const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
  const match = url.match(regExp);
  return (match && match[2].length === 11) 
    ? `https://www.youtube.com/embed/${match[2]}` 
    : null;
}

const embedUrl = getYoutubeEmbedUrl(lessonData.video_url);
---

<Layout title={lessonData.name}>
  <!-- Mobile Sidebar Toggle -->
  <div class="lg:hidden mb-4">
    <button id="lesson-sidebar-toggle" class="flex items-center space-x-2 text-sm font-bold text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/20 px-4 py-2 rounded-xl w-full justify-between">
      <span>Danh sách bài học</span>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 10a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 15a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd" />
      </svg>
    </button>
  </div>

  <div class="flex flex-col lg:flex-row gap-8 max-w-7xl mx-auto">
    <!-- Sidebar -->
    <aside id="lesson-sidebar" class="hidden lg:block w-full lg:w-80 shrink-0">
      <div class="sticky top-24 bg-white dark:bg-slate-900 border border-gray-200 dark:border-slate-800 rounded-2xl p-5 shadow-sm">
        <h3 class="font-bold text-lg text-gray-900 dark:text-white mb-4 flex items-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-blue-500" viewBox="0 0 20 20" fill="currentColor">
            <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z" />
          </svg>
          Môn {subject?.name || entry.data.subject}
        </h3>
        
        <div class="space-y-1 overflow-y-auto max-h-[calc(100vh-200px)] custom-scrollbar pr-2">
          {subjectLessons.map((l, index) => (
            <a 
              href={`/${subjectParam}/${getSlug(l.id)}`}
              class:list={['block px-3 py-2.5 rounded-xl text-sm font-medium transition-colors', l.id === entry.id ? 'bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400 border border-blue-100 dark:border-blue-800/50' : 'text-gray-600 dark:text-slate-400 hover:bg-gray-50 dark:hover:bg-slate-800/50 hover:text-gray-900 dark:hover:text-slate-200 border border-transparent']}
            >
              <div class="flex gap-3">
                <span class:list={['shrink-0 font-bold', l.id === entry.id ? 'text-blue-500' : 'text-gray-400']}>
                  {index + 1}.
                </span>
                <span class="line-clamp-2 leading-snug">{l.data.lessons[0].name}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </aside>

    <!-- Main Content -->
    <div class="flex-1 space-y-8 min-w-0">
      <!-- Breadcrumb -->
    <div>
      {subject && (
        <a href={"/ly-thuyet/" + subject.slug} class="inline-flex items-center text-xs font-bold text-gray-400 hover:text-gray-600 dark:hover:text-slate-350 transition-colors uppercase tracking-wider mb-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          Môn {subject.name}
        </a>
      )}
      
      <h1 class="text-2xl md:text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight leading-snug">
        {lessonData.name}
      </h1>
    </div>

    <!-- Video lecture embed -->
    {embedUrl && (
      <div class="aspect-video w-full rounded-2xl overflow-hidden border border-gray-250 dark:border-slate-800/80 shadow-md bg-black">
        <iframe
          class="w-full h-full"
          src={embedUrl}
          title={"Bài giảng: " + lessonData.name}
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
      </div>
    )}

    <!-- Lesson Content -->
    <div class="bg-white dark:bg-slate-900 border border-gray-250 dark:border-slate-800/80 rounded-2xl p-6 md:p-8 shadow-sm">
      <div class="prose dark:prose-invert max-w-none text-base select-text">
        {lessonData.content?.theory?.sections?.map((section: any) => (
          <div class="mb-8">
            <h2 class="text-xl font-bold text-blue-600 dark:text-blue-400 mb-4">{section.heading}</h2>
            <div set:html={section.content} class="prose-content" />
          </div>
        ))}

        {lessonData.content?.problemTypes?.map((pt: any) => (
          <div class="mt-12 border-t border-gray-200 dark:border-slate-800 pt-8">
            <h2 class="text-xl font-bold text-blue-600 dark:text-blue-400 mb-6">{pt.name}</h2>
            <div class="bg-blue-50 dark:bg-blue-900/20 rounded-xl p-6 mb-8 border border-blue-100 dark:border-blue-800/50">
              <div set:html={pt.method} />
            </div>
            
            <div class="space-y-6">
              {pt.examples?.map((ex: any) => (
                <div class="bg-white dark:bg-slate-950 rounded-xl p-6 border border-gray-200 dark:border-slate-800 shadow-sm">
                  <div class="mb-4" set:html={ex.question} />
                  <div class="pt-4 border-t border-gray-100 dark:border-slate-800" set:html={ex.solution} />
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>



    <!-- Quick Quiz Section -->
    {quizQuestions.length > 0 && (
      <div class="border-t border-gray-250 dark:border-slate-850 pt-8" id="quick-quiz-section">
        <div class="flex items-center space-x-2 mb-6">
          <div class="w-2.5 h-5 rounded-sm bg-blue-600"></div>
          <h2 class="text-xl font-bold text-gray-900 dark:text-white">Luyện tập trắc nghiệm</h2>
          <span class="ml-2 px-2 py-0.5 rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400 text-xs font-bold" id="quiz-counter">1 / {quizQuestions.length}</span>
        </div>

        <div id="quick-quiz-container">
          {quizQuestions.map((q, index) => (
            <div class="quiz-question-wrapper" data-index={index} style={index === 0 ? '' : 'display: none;'}>
              <QuestionCard question={q} index={index + 1} mode="take" />
              
              <div class="quiz-feedback-box hidden mt-6 p-6 rounded-2xl border transition-colors duration-200">
                <div class="flex items-center space-x-3 mb-3">
                  <span class="feedback-icon w-8 h-8 rounded-full flex items-center justify-center text-white"></span>
                  <h4 class="feedback-title font-bold text-base"></h4>
                </div>
                <p class="feedback-text text-sm leading-relaxed mb-4"></p>
                
                <div class="p-4 rounded-xl bg-black/5 dark:bg-white/5 border border-black/10 dark:border-white/5">
                  <h5 class="text-xs font-bold text-gray-500 dark:text-slate-400 uppercase tracking-wider mb-1">Lời giải chi tiết:</h5>
                  <p class="text-sm text-gray-700 dark:text-slate-300 leading-relaxed font-medium">
                    {q.explanation || 'Không có lời giải chi tiết cho câu hỏi này.'}
                  </p>
                </div>
              </div>
            </div>
          ))}
          
          <div class="flex justify-end mt-4 space-x-3">
            <button
              id="retry-quiz-btn"
              class="hidden bg-gray-200 hover:bg-gray-300 text-gray-800 font-semibold px-5 py-2.5 rounded-xl shadow-sm text-sm transition dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-slate-700"
            >
              Làm lại
            </button>
            <button
              id="check-answer-btn"
              class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-5 py-2.5 rounded-xl shadow text-sm transition"
            >
              Kiểm tra đáp án
            </button>
            <button
              id="next-question-btn"
              class="hidden bg-blue-600 hover:bg-blue-700 text-white font-semibold px-5 py-2.5 rounded-xl shadow text-sm transition"
            >
              Làm tiếp
            </button>
          </div>
        </div>
        
        <div id="quiz-final-result" class="hidden mt-6 p-8 text-center rounded-2xl bg-blue-50 dark:bg-blue-900/20 border border-blue-100 dark:border-blue-800/50">
          <h3 class="text-2xl font-bold text-blue-700 dark:text-blue-400 mb-2">Hoàn thành bài tập!</h3>
          <p class="text-gray-600 dark:text-slate-300 mb-4" id="quiz-final-score"></p>
          <button
             onclick="window.location.reload()"
             class="bg-blue-600 hover:bg-blue-700 text-white font-bold px-6 py-3 rounded-xl shadow-sm transition inline-flex items-center"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
             Làm lại từ đầu
          </button>
        </div>
      </div>
    )}
      <!-- Next / Prev Buttons -->
      <div class="flex items-center justify-between pt-8 border-t border-gray-250 dark:border-slate-850 mt-12 gap-4">
        {prevLesson ? (
          <a href={"/" + subjectParam + "/" + getSlug(prevLesson.id)} class="flex-1 group flex flex-col p-4 rounded-2xl border border-gray-200 dark:border-slate-800 hover:border-blue-300 dark:hover:border-blue-700 bg-white dark:bg-slate-900 hover:shadow-md transition-all">
            <span class="text-xs font-bold text-gray-500 dark:text-slate-400 uppercase tracking-wider mb-2 flex items-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1 transform group-hover:-translate-x-1 transition-transform" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
              </svg>
              Bài trước
            </span>
            <span class="font-bold text-sm text-gray-900 dark:text-slate-200 group-hover:text-blue-600 dark:group-hover:text-blue-400 line-clamp-2">
              {prevLesson.data.lessons[0].name}
            </span>
          </a>
        ) : <div class="flex-1"></div>}

        {nextLesson ? (
          <a href={"/" + subjectParam + "/" + getSlug(nextLesson.id)} class="flex-1 group flex flex-col p-4 rounded-2xl border border-gray-200 dark:border-slate-800 hover:border-blue-300 dark:hover:border-blue-700 bg-white dark:bg-slate-900 hover:shadow-md transition-all text-right items-end">
            <span class="text-xs font-bold text-gray-500 dark:text-slate-400 uppercase tracking-wider mb-2 flex items-center">
              Bài tiếp theo
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1 transform group-hover:translate-x-1 transition-transform" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </span>
            <span class="font-bold text-sm text-gray-900 dark:text-slate-200 group-hover:text-blue-600 dark:group-hover:text-blue-400 line-clamp-2">
              {nextLesson.data.lessons[0].name}
            </span>
          </a>
        ) : <div class="flex-1"></div>}
      </div>

    </div>
  </div>
</Layout>

<script define:vars={{ quizData: quizQuestions.map(q => ({ id: q.id, type: q.type, correctAnswers: q.answers.filter(a => a.is_correct).map(a => a.id), answers: q.answers, answer: q.answer })) }}>
  let currentQuestionIndex = 0;
  const totalQuestions = quizData.length;
  let score = 0;
  
  const selectedAnswersMap = {};
  quizData.forEach(q => selectedAnswersMap[q.id] = []);

  document.addEventListener('answer-selected', (e) => {
    // @ts-ignore
    const { questionId, answerId, type, choice, answerText } = e.detail;
    
    let selected = selectedAnswersMap[questionId];
    if (!selected || selected.length === 0) {
      if (type === 'msq') selected = [{}];
      else selected = [];
    }
    
    if (type === 'single_choice' || type === 'true_false') {
      selected = [answerId];
    } else if (type === 'multiple_choice') {
      const idx = selected.indexOf(answerId);
      if (idx > -1) selected.splice(idx, 1);
      else selected.push(answerId);
    } else if (type === 'msq') {
      if (!selected[0]) selected[0] = {};
      selected[0][answerId] = choice;
    } else if (type === 'sa' || type === 'tl') {
      selected = [answerText];
    }
    selectedAnswersMap[questionId] = selected;
  });

  const checkBtn = document.getElementById('check-answer-btn');
  const nextBtn = document.getElementById('next-question-btn');
  const retryBtn = document.getElementById('retry-quiz-btn');
  const counter = document.getElementById('quiz-counter');
  
  if (checkBtn && nextBtn) {
    checkBtn.addEventListener('click', () => {
      const qData = quizData[currentQuestionIndex];
      const selectedAnswersList = selectedAnswersMap[qData.id];
      
      let isCorrect = false;

      if (qData.type === 'single_choice' || qData.type === 'multiple_choice') {
        if (!selectedAnswersList || selectedAnswersList.length === 0) {
          alert('Cậu hãy chọn ít nhất một đáp án trước khi kiểm tra nhé!');
          return;
        }
        const allCorrectSelected = qData.correctAnswers.every(id => selectedAnswersList.includes(id));
        const noIncorrectSelected = selectedAnswersList.every(id => qData.correctAnswers.includes(id));
        isCorrect = allCorrectSelected && noIncorrectSelected && qData.correctAnswers.length === selectedAnswersList.length;
      } else if (qData.type === 'msq') {
        const submittedObj = selectedAnswersList[0] || {};
        if (Object.keys(submittedObj).length !== qData.answers.length) {
          alert('Cậu hãy chọn Đúng/Sai cho tất cả các ý nhé!');
          return;
        }
        isCorrect = true;
        qData.answers.forEach(a => {
          const expected = qData.correctAnswers.includes(a.id) ? 'Đúng' : 'Sai';
          if (submittedObj[a.id] !== expected) isCorrect = false;
        });
      } else if (qData.type === 'sa') {
        const submitted = selectedAnswersList[0] || '';
        if (!submitted.trim()) {
          alert('Cậu hãy nhập câu trả lời nhé!');
          return;
        }
        const normSub = submitted.trim().toLowerCase().replace(/\s+/g, ' ').replace(',', '.');
        const normCorr = (qData.answer || '').toString().trim().toLowerCase().replace(/\s+/g, ' ').replace(',', '.');
        isCorrect = normSub === normCorr || (!isNaN(Number(normSub)) && !isNaN(Number(normCorr)) && Number(normSub) === Number(normCorr));
      } else if (qData.type === 'tl') {
        isCorrect = true; 
      }

      if (isCorrect) score++;

      const wrapper = document.querySelector(`.quiz-question-wrapper[data-index="${currentQuestionIndex}"]`);
      if (!wrapper) return;
      
      // Visual feedback
      if (qData.type === 'single_choice' || qData.type === 'multiple_choice') {
        wrapper.querySelectorAll('.option-item').forEach(item => {
          // @ts-ignore
          item.style.pointerEvents = 'none';
          const ansId = item.getAttribute('data-answer-id');
          if (qData.correctAnswers.includes(ansId)) {
            item.classList.remove('border-blue-500', 'bg-blue-50/50', 'text-blue-700', 'dark:border-blue-500');
            item.classList.add('border-emerald-500', 'bg-emerald-50/40', 'text-emerald-700', 'dark:text-emerald-400');
            const letter = item.querySelector('.w-6');
            if (letter) {
              letter.classList.remove('bg-blue-600', 'border-blue-600', 'bg-blue-100', 'border-blue-300', 'text-blue-700', 'dark:bg-blue-900/60', 'dark:border-blue-800', 'dark:text-blue-300');
              letter.classList.add('bg-emerald-600', 'border-emerald-600', 'text-white');
            }
          } else if (selectedAnswersList.includes(ansId)) {
            item.classList.remove('border-blue-500', 'bg-blue-50/50', 'text-blue-700', 'dark:border-blue-500');
            item.classList.add('border-rose-500', 'bg-rose-50/40', 'text-rose-700', 'dark:text-rose-400');
            const letter = item.querySelector('.w-6');
            if (letter) {
              letter.classList.remove('bg-blue-600', 'border-blue-600', 'bg-blue-100', 'border-blue-300', 'text-blue-700', 'dark:bg-blue-900/60', 'dark:border-blue-800', 'dark:text-blue-300');
              letter.classList.add('bg-rose-600', 'border-rose-600', 'text-white');
            }
          }
        });
      } else if (qData.type === 'msq') {
        const submittedObj = selectedAnswersList[0] || {};
        wrapper.querySelectorAll('[data-msq-button]').forEach(btn => {
          // @ts-ignore
          btn.style.pointerEvents = 'none';
        });
        wrapper.querySelectorAll('.msq-row').forEach(row => {
          const ansId = row.getAttribute('data-answer-id');
          const expected = qData.correctAnswers.includes(ansId) ? 'Đúng' : 'Sai';
          const submitted = submittedObj[ansId];
          const isRowCorrect = submitted === expected;
          
          row.classList.remove('border-blue-500', 'bg-blue-50/30', 'dark:border-blue-500', 'dark:bg-blue-950/20');
          const letter = row.querySelector('.msq-letter');
          
          if (isRowCorrect) {
             row.classList.add('border-emerald-500', 'bg-emerald-50/40', 'text-emerald-700', 'dark:border-emerald-500');
             if (letter) {
               letter.classList.remove('bg-blue-600', 'bg-gray-100', 'text-gray-500', 'dark:bg-slate-800', 'dark:text-slate-450');
               letter.classList.add('bg-emerald-600', 'text-white', 'dark:bg-emerald-600');
             }
          } else {
             row.classList.add('border-rose-500', 'bg-rose-50/40', 'text-rose-700', 'dark:border-rose-500');
             if (letter) {
               letter.classList.remove('bg-blue-600', 'bg-gray-100', 'text-gray-500', 'dark:bg-slate-800', 'dark:text-slate-450');
               letter.classList.add('bg-rose-600', 'text-white', 'dark:bg-rose-600');
             }
          }

          const btnContainer = row.querySelector('.flex.items-center.gap-3.shrink-0');
          if (btnContainer) {
            const correctBadge = document.createElement('span');
            correctBadge.className = 'ml-2 text-xs font-bold px-2 py-1 rounded border ' + (isRowCorrect ? 'bg-emerald-100 text-emerald-700 border-emerald-200 dark:bg-emerald-950/20 dark:text-emerald-400' : 'bg-rose-100 text-rose-700 border-rose-200 dark:bg-rose-950/20 dark:text-rose-400');
            correctBadge.innerHTML = isRowCorrect ? '✓' : `Đáp án: ${expected}`;
            btnContainer.appendChild(correctBadge);
          }
        });
      } else if (qData.type === 'sa' || qData.type === 'tl') {
        const inputs = wrapper.querySelectorAll('input, textarea');
        inputs.forEach(inp => {
           // @ts-ignore
           inp.style.pointerEvents = 'none';
           if (qData.type === 'sa') {
             inp.classList.add(isCorrect ? 'border-emerald-500' : 'border-rose-500');
           }
        });
      }

      // Show feedback
      const feedbackBox = wrapper.querySelector('.quiz-feedback-box');
      const feedbackIcon = wrapper.querySelector('.feedback-icon');
      const feedbackTitle = wrapper.querySelector('.feedback-title');
      const feedbackText = wrapper.querySelector('.feedback-text');

      if (feedbackBox && feedbackIcon && feedbackTitle && feedbackText) {
        feedbackBox.classList.remove('hidden');
        if (isCorrect) {
          feedbackBox.classList.add('bg-emerald-50/50', 'border-emerald-200/50', 'dark:bg-emerald-950/15', 'dark:border-emerald-900/35');
          feedbackIcon.className = 'feedback-icon w-8 h-8 rounded-full flex items-center justify-center bg-emerald-500 text-white font-bold';
          feedbackIcon.innerHTML = '✓';
          feedbackTitle.className = 'feedback-title font-bold text-emerald-800 dark:text-emerald-400 text-base';
          feedbackTitle.textContent = qData.type === 'tl' ? 'Đã ghi nhận bài làm!' : 'Chính xác! Chúc mừng cậu.';
          feedbackText.className = 'feedback-text text-sm text-emerald-700 dark:text-emerald-300 leading-relaxed mb-4';
          feedbackText.textContent = qData.type === 'tl' ? 'Cậu hãy đối chiếu với lời giải chi tiết bên dưới nhé.' : 'Cậu đã phân tích rất tốt và chọn đúng phương án.';
        } else {
          feedbackBox.classList.add('bg-rose-50/50', 'border-rose-200/50', 'dark:bg-rose-950/15', 'dark:border-rose-900/35');
          feedbackIcon.className = 'feedback-icon w-8 h-8 rounded-full flex items-center justify-center bg-rose-500 text-white font-bold';
          feedbackIcon.innerHTML = '✗';
          feedbackTitle.className = 'feedback-title font-bold text-rose-800 dark:text-rose-400 text-base';
          feedbackTitle.textContent = 'Tiếc quá, chưa chính xác mất rồi.';
          feedbackText.className = 'feedback-text text-sm text-rose-700 dark:text-rose-300 leading-relaxed mb-4';
          if (qData.type === 'sa') {
            feedbackText.innerHTML = `Đáp án chính xác là: <strong>${qData.answer}</strong>. Cậu hãy xem kỹ lại lời giải nhé!`;
          } else {
            feedbackText.textContent = 'Cậu hãy xem kỹ lại lời giải chi tiết bên dưới nhé!';
          }
        }

        // @ts-ignore
        if (typeof renderMathInElement === 'function') {
          // @ts-ignore
          renderMathInElement(feedbackBox, {
            delimiters: [ { left: '$$', right: '$$', display: true }, { left: '$', right: '$', display: false } ],
            throwOnError: false
          });
        }
      }

      checkBtn.classList.add('hidden');
      if (currentQuestionIndex < totalQuestions - 1) {
        nextBtn.classList.remove('hidden');
      } else {
        retryBtn.classList.remove('hidden');
        const finalResult = document.getElementById('quiz-final-result');
        const scoreText = document.getElementById('quiz-final-score');
        if (finalResult && scoreText) {
          finalResult.classList.remove('hidden');
          scoreText.innerHTML = `Cậu đã hoàn thành bài tập. Trả lời đúng <strong>${score}/${totalQuestions}</strong> câu hỏi.`;
        }
      }
    });

    nextBtn.addEventListener('click', () => {
      const oldWrapper = document.querySelector(`.quiz-question-wrapper[data-index="${currentQuestionIndex}"]`);
      if (oldWrapper) {
        // @ts-ignore
        oldWrapper.style.display = 'none';
      }
      
      currentQuestionIndex++;
      const newWrapper = document.querySelector(`.quiz-question-wrapper[data-index="${currentQuestionIndex}"]`);
      if (newWrapper) {
        // @ts-ignore
        newWrapper.style.display = 'block';
      }
      
      if (counter) counter.textContent = `${currentQuestionIndex + 1} / ${totalQuestions}`;
      
      nextBtn.classList.add('hidden');
      checkBtn.classList.remove('hidden');
    });

    retryBtn.addEventListener('click', () => {
      window.location.reload();
    });
  }
</script>

<script>
  // Mobile sidebar toggle script
  const toggleBtn = document.getElementById('lesson-sidebar-toggle');
  const sidebar = document.getElementById('lesson-sidebar');

  if (toggleBtn && sidebar) {
    toggleBtn.addEventListener('click', () => {
      sidebar.classList.toggle('hidden');
    });
  }
</script>

