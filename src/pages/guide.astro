---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Hướng dẫn sử dụng" description="Hướng dẫn chi tiết cách tham gia học tập, thi thử trắc nghiệm online và sử dụng trợ lý ảo AI trên cổng Lớp 12 LMS.">
  <div class="space-y-12 max-w-4xl mx-auto">
    <!-- Header -->
    <div class="text-center space-y-4">
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight font-outfit text-gray-900 dark:text-white">
        Hướng dẫn học tập trên Lớp 12 LMS
      </h1>
      <p class="text-sm md:text-base text-gray-550 dark:text-slate-400 font-semibold max-w-2xl mx-auto">
        Chỉ với vài thao tác đơn giản, cậu đã có thể bắt đầu hành trình ôn tập hiệu quả cùng hàng nghìn bài giảng và đề thi chất lượng.
      </p>
    </div>

    <!-- Steps -->
    <div class="space-y-8">
      {[
        {
          step: '01',
          title: 'Đăng ký tài khoản học tập',
          content: 'Nhấn nút "Đăng ký" tại trang chủ hoặc truy cập trực tiếp trang đăng ký. Điền đầy đủ thông tin: Họ tên, Email và Mật khẩu để tạo tài khoản. Bạn cũng có thể đăng nhập tức thì thông qua tài khoản Google.',
          color: 'from-blue-500 to-indigo-500',
          badgeColor: 'bg-blue-500/10 text-blue-600 dark:text-blue-400'
        },
        {
          step: '02',
          title: 'Học lý thuyết và xem bài giảng',
          content: 'Vào mục "Môn học" từ Sidebar hoặc Dashboard, chọn môn học mong muốn (Toán, Lý, Hóa...). Chọn từng bài giảng để xem video hướng dẫn chi tiết và đọc tóm tắt lý thuyết, ví dụ minh họa định dạng LaTeX toán học sắc nét.',
          color: 'from-indigo-500 to-purple-500',
          badgeColor: 'bg-indigo-500/10 text-indigo-600 dark:text-indigo-400'
        },
        {
          step: '03',
          title: 'Luyện đề trắc nghiệm online',
          content: 'Truy cập mục "Đề thi" để thử sức với các bài thi 15 phút, 45 phút, thi học kỳ hoặc thi thử THPT Quốc gia. Hệ thống sẽ đếm ngược thời gian làm bài thực tế. Khi nộp bài, bạn sẽ nhận được điểm số, lời giải chi tiết và đáp án đối chiếu ngay lập tức.',
          color: 'from-purple-500 to-pink-500',
          badgeColor: 'bg-purple-500/10 text-purple-600 dark:text-purple-400'
        },
        {
          step: '04',
          title: 'Hỏi đáp bài tập khó với Trợ lý AI',
          content: 'Khi gặp bài tập khó hoặc phần lý thuyết chưa hiểu, hãy nhấn vào "Hỏi đáp AI". Chatbot thông minh sẽ hỗ trợ phân tích đề, đưa ra hướng giải chi tiết bằng công thức toán học dễ hiểu và hướng dẫn từng bước.',
          color: 'from-pink-500 to-rose-500',
          badgeColor: 'bg-pink-500/10 text-rose-600 dark:text-rose-400'
        }
      ].map((item, index) => (
        <div class="flex flex-col md:flex-row gap-6 p-6 md:p-8 bg-white dark:bg-slate-900 border border-gray-200/60 dark:border-slate-800/80 rounded-3xl shadow-sm hover:border-blue-500/30 transition-all duration-200">
          <div class="flex-shrink-0 flex items-center md:items-start">
            <span class={`w-14 h-14 rounded-2xl bg-gradient-to-br ${item.color} flex items-center justify-center font-bold text-white text-xl shadow-lg shadow-blue-500/5 font-outfit`}>
              {item.step}
            </span>
          </div>
          <div class="space-y-2">
            <h3 class="text-xl font-bold text-gray-900 dark:text-white font-outfit">{item.title}</h3>
            <p class="text-sm md:text-base text-gray-500 dark:text-slate-400 leading-relaxed font-medium">
              {item.content}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- Additional tips for admin/teacher -->
    <div class="p-6 md:p-8 bg-blue-50/50 dark:bg-blue-950/20 border border-blue-100/50 dark:border-blue-900/50 rounded-3xl space-y-4">
      <div class="flex items-center gap-3">
        <span class="text-2xl">👩‍🏫</span>
        <h4 class="text-lg font-bold text-blue-900 dark:text-blue-400 font-outfit">Lưu ý dành cho Giáo viên & Quản trị viên</h4>
      </div>
      <p class="text-sm text-blue-700 dark:text-slate-350 leading-relaxed font-medium">
        Nếu tài khoản của cậu được cấp quyền <strong>Teacher</strong> hoặc <strong>Admin</strong>, một tùy chọn <strong>"Quản trị"</strong> sẽ xuất hiện trên thanh Sidebar. 
        Tại đây, giáo viên có thể thêm/sửa/xóa bài học, quản lý kho câu hỏi trắc nghiệm phong phú và tự tay biên soạn, thiết lập các bộ đề thi thử chất lượng cao cho học sinh.
      </p>
    </div>
  </div>
</Layout>
