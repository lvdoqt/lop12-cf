# Supabase Config
# URL of your Supabase project (e.g. https://xxxxxx.supabase.co)
SUPABASE_URL=https://your-project-id.supabase.co

# Public anon key (safe to expose in frontend code)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (strictly server-side, bypasses RLS, used for administrative actions)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# LLM Config (Optional - fallback to intelligent mock answers if not provided)
GEMINI_API_KEY=

# WordPress API Config
WORDPRESS_API_URL=
